---
import Analytics from '../components/Analytics.astro';
import '../styles/global.css';

interface Props {
  slug: string;
  formName: string;
  meta: { title: string; description: string };
  images: {
    hero: string;
    aha1: string;
    aha2: string;
    aha3: string;
    qualifier: string;
    footer: string;
    currentPositioning: string;
  };
  hero: {
    label?: string;
    h1: string;
    lead: string;
    offerLine: string;
    ctaText?: string;
    cardH2: string;
    cardMeta: string;
    cardBody: string;
  };
  triggerPoints: string[];
  selfSelection: string[];
  responseCards: Array<{
    number: string;
    title: string;
    problem: string;
    answer: string;
    detail: string;
    cta?: string;
    image: string;
    alt: string;
  }>;
  comparisons: Array<{
    overline: string;
    title: string;
    text: string;
  }>;
  processSteps: Array<{
    number: string;
    title: string;
    text: string;
  }>;
  sections: {
    immersive1?: {
      eyebrow?: string;
      h2?: string;
      bodies?: string[];
      facts?: string[];
      bridge?: string;
    };
    responses?: { h2?: string };
    splitPhoto?: {
      eyebrow?: string;
      h2?: string;
      quoteText?: string;
      quoteFooter?: string;
      link?: string;
    };
    story?: {
      number?: string;
      h2?: string;
      problem?: string;
      body?: string;
      link?: string;
    };
    process?: { h2?: string; lead?: string };
    final?: {
      eyebrow?: string;
      h2?: string;
      lead?: string;
      formEyebrow?: string;
      formTitle?: string;
      formLead?: string;
    };
  };
}

const {
  slug,
  formName,
  meta,
  images,
  hero,
  triggerPoints,
  selfSelection,
  responseCards,
  comparisons,
  processSteps,
  sections: s,
  heroVariant = 'default',
} = Astro.props;
---
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{meta.title}</title>
    <meta name="description" content={meta.description} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  </head>
  <body class="landing-745">
    <Analytics landingSlug={slug} />
    <main>
      <!-- HERO -->
      {heroVariant === 'dtbd' ? (
        <section class="hero745 section section--photo-hero hero745--dtbd">
          <div class="hero745__backdrop" style={`--section-bg: url(${images.hero})`}></div>
          <div class="container hero745__container hero745__container--dtbd">
            <div class="hero745__toprow">
              <span class="hero745__label hero745__label--large" set:html={hero.label}></span>
              {hero.cardMeta && <span class="hero745__meta hero745__meta--toprow" set:html={hero.cardMeta}></span>}
            </div>
            <h1 class="hero745__h1--dtbd" set:html={hero.h1}></h1>
            {(triggerPoints ?? []).length > 0 && (
              <div class="hero745__triggers">
                {(triggerPoints ?? []).map((item: string) => (
                  <p class="hero745__trigger" set:html={item}></p>
                ))}
              </div>
            )}
            <div class="hero745__actions hero745__actions--dtbd">
              <a class="button745 button745--primary" href="#contact" set:html={hero.ctaText || 'Получить планировки и расчёт ипотеки'}></a>
              {hero.ctaSecondary && <a class="button745 button745--ghost" href="#contact" set:html={hero.ctaSecondary}></a>}
            </div>
          </div>
        </section>
      ) : (
        <>
        <section class="hero745 section section--photo-hero">
          <div class="hero745__backdrop" style={`--section-bg: url(${images.hero})`}></div>
          <div class="container hero745__container">
            {hero.label && <div class="hero745__label" set:html={hero.label}></div>}
            <div class="hero745__grid">
              <div class="hero745__content hero745__content--glass">
                <h1 set:html={hero.h1}></h1>
                <p class="hero745__lead" set:html={hero.lead}></p>
                <p class="hero745__offer-line" set:html={hero.offerLine}></p>
                <div class="hero745__actions hero745__actions--stacked">
                  <a class="button745 button745--primary" href="#contact" set:html={hero.ctaText || 'Посмотреть, как этот сценарий упаковать для проекта'}></a>
                </div>
              </div>
              <aside class="hero745__card hero745__card--floating">
                <div class="hero745__card-body">
                  <h2 set:html={hero.cardH2}></h2>
                  <p class="hero745__meta" set:html={hero.cardMeta}></p>
                  <p set:html={hero.cardBody}></p>
                </div>
              </aside>
            </div>
          </div>
        </section>
        <section class="section section--tight triggers745-wrap triggers745-wrap--hero-continued">
          <div class="hero745__backdrop hero745__backdrop--continued" style={`--section-bg: url(${images.hero})`}></div>
          <div class="triggers745__tone"></div>
          <div class="container triggers745__container">
            {s.triggers?.h2 && <h2 set:html={s.triggers.h2}></h2>}
            <div class="triggers745">
              {(triggerPoints ?? []).map((item: string) => <p set:html={item}></p>)}
            </div>
          </div>
        </section>
        </>
      )}
      <!-- IMMERSIVE 1 -->
      <section class="immersive745 immersive745--hero" style={`--immersive-bg: url(${images.aha1})`}>
        <div class="container immersive745__inner">
          <div class="immersive745__card">
            {s.immersive1?.eyebrow && <p class="immersive745__eyebrow" set:html={s.immersive1.eyebrow}></p>}
            {s.immersive1?.h2 && <h2 set:html={s.immersive1.h2}></h2>}
            {s.immersive1?.bodies?.map((b: string) => (
              <p set:html={b}></p>
            ))}
            {s.immersive1?.facts && s.immersive1.facts.length > 0 && (
              <div class="immersive745__facts">
                {s.immersive1.facts.map((f: string) => <span set:html={f}></span>)}
              </div>
            )}
            {s.immersive1?.bridge && (
              <p class="immersive745__bridge immersive745__bridge--light" set:html={s.immersive1.bridge}></p>
            )}
          </div>
        </div>
      </section>
      <!-- RESPONSE CARDS -->
      <section class="section responses745 section--photo-soft" style={`--section-bg: url(${images.aha2})`}>
        <div class="responses745__veil"></div>
        <div class="container responses745__container">
          <div class="section745-heading center745 section745-heading--light">
            {s.responses?.h2 && <h2 set:html={s.responses.h2}></h2>}
          </div>
          <div class="responses745__stack">
            {(responseCards ?? []).map((card: any) => (
              <article class="response745-card">
                <div class="response745-card__media">
                  <img src={card.image || images[`aha${(responseCards ?? []).indexOf(card) + 1}`]} alt={card.alt} loading="lazy" />
                </div>
                <div class="response745-card__body">
                  <div class="response745-card__number">{card.number}</div>
                  <h3 set:html={card.title || card.h3}></h3>
                  <p class="response745-card__problem" set:html={card.problem || card.eyebrow}></p>
                  <p set:html={card.answer || card.body}></p>
                  <p class="response745-card__detail" set:html={card.detail}></p>
                  {card.cta && (
                    <a class="inline-link745" href="#contact">{card.cta}</a>
                  )}
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
      <!-- SPLIT PHOTO / SELF-SELECTION -->
      <section class="split-photo745">
        <div class="split-photo745__image" style={`--split-bg: url(${images.qualifier})`}></div>
        <div class="split-photo745__content-wrap">
          <div class="container split-photo745__container">
            <div class="split-photo745__content">
              {s.splitPhoto?.eyebrow && <p class="immersive745__eyebrow" set:html={s.splitPhoto.eyebrow}></p>}
              {s.splitPhoto?.h2 && <h2 set:html={s.splitPhoto.h2}></h2>}
              <div class="self745 self745--transparent">
                {(selfSelection ?? []).map((item: string) => <p set:html={item}></p>)}
              </div>
              {s.splitPhoto?.quoteText && (
                <blockquote class="quote745 quote745--light">
                  <p set:html={s.splitPhoto.quoteText}></p>
                  {s.splitPhoto?.quoteFooter && <footer set:html={s.splitPhoto.quoteFooter}></footer>}
                </blockquote>
              )}
              {s.splitPhoto?.link && (
                <a class="inline-link745 inline-link745--light" href="#contact" set:html={s.splitPhoto.link}></a>
              )}
            </div>
          </div>
        </div>
      </section>
      <!-- STORY / IMMERSIVE 2 -->
      <section class="immersive745 immersive745--contrast" style={`--immersive-bg: url(${images.aha3})`}>
        <div class="container immersive745__inner immersive745__inner--right">
          <div class="immersive745__card immersive745__card--single-story">
            <div class="story745-card">
              {s.story?.number && <div class="story745-card__number">{s.story.number}</div>}
              {s.story?.h2 && <h2 set:html={s.story.h2}></h2>}
              {s.story?.problem && <p class="story745-card__problem" set:html={s.story.problem}></p>}
              {s.story?.body && <p set:html={s.story.body}></p>}
              {s.story?.link && (
                <a class="inline-link745" href="#contact" set:html={s.story.link}></a>
              )}
            </div>
          </div>
        </div>
      </section>
      <!-- PROCESS STEPS -->
      <section class="section process745 section--photo-band" style={`--section-bg: url(${images.footer})`}>
        <div class="section-band745__overlay section-band745__overlay--dark"></div>
        <div class="container process745__container">
          <div class="section745-heading center745 section745-heading--light section745-heading--max">
            {s.process?.h2 && <h2 set:html={s.process.h2}></h2>}
            {s.process?.lead && <p set:html={s.process.lead}></p>}
          </div>
          <div class="process745__grid process745__grid--stacked">
            {(processSteps ?? []).map((step) => (
              <article class="process745-card process745-card--light process745-card--stacked">
                <div class="process745-card__number">{step.number}</div>
                <h3>{step.title}</h3>
                <p>{step.text}</p>
              </article>
            ))}
          </div>
        </div>
      </section>
      <!-- FINAL / CTA -->
      <section id="contact" class="section final745 final745--photo">
        <div class="final745__backdrop" style={`--final-bg: url(${images.footer})`}></div>
        <div class="container final745__container">
          <div class="final745__layout">
            <div class="final745__media-copy">
              {s.final?.eyebrow && <p class="final745__eyebrow" set:html={s.final.eyebrow}></p>}
              {s.final?.h2 && <h2 set:html={s.final.h2}></h2>}
              {s.final?.lead && (
                <p class="final745__lead final745__lead--light" set:html={s.final.lead}></p>
              )}
              <div class="final745__positioning-shot">
                <img src={images.currentPositioning} alt={`Текущее позиционирование — ${meta.title}`} loading="lazy" />
              </div>
            </div>
            <div class="final745__card">
              {s.final?.formEyebrow && (
                <p class="final745__eyebrow" set:html={s.final.formEyebrow}></p>
              )}
              {s.final?.formTitle && (
                <h3 class="final745__form-title" set:html={s.final.formTitle}></h3>
              )}
              {s.final?.formLead && (
                <p class="final745__lead" set:html={s.final.formLead}></p>
              )}
              <form
                name={formName}
                method="POST"
                data-netlify="true"
                netlify-honeypot="bot-field"
                action="/thank-you"
                class="final745__form"
              >
                <input type="hidden" name="form-name" value={formName} />
                <input type="hidden" name="landing_slug" value={slug} />
                <input type="hidden" name="utm_source" value="" />
                <input type="hidden" name="utm_medium" value="" />
                <input type="hidden" name="utm_campaign" value="" />
                <input type="hidden" name="utm_content" value="" />
                <input type="hidden" name="utm_term" value="" />
                <p class="sr-only">
                  <label>
                    Не заполняйте это поле, если вы человек:
                    <input name="bot-field" />
                  </label>
                </p>
                <div class="final745__form-grid">
                  <div class="final745__field-block">
                    <label for="name" class="field-label745">Имя</label>
                    <input type="text" id="name" name="name" required class="field-input745" />
                  </div>
                  <div class="final745__field-block final745__form-full">
                    <label for="phone" class="field-label745">Телефон / Telegram</label>
                    <input type="tel" id="phone" name="phone" required class="field-input745" />
                  </div>
                  <div class="final745__field-block final745__form-full">
                    <label for="email" class="field-label745">Email</label>
                    <input type="email" id="email" name="email" required class="field-input745" />
                  </div>
                </div>
                <button type="submit" class="button745 button745--primary final745__submit">
                  Записаться на встречу
                </button>
                {s.final?.submitNote && (
                  <p class="final745__submit-note" set:html={s.final.submitNote}></p>
                )}
              </form>
            </div>
          </div>
        </div>
      </section>
    </main>
    <script define:vars={{ slug }}>
      import { populateUTMFields, trackFormSubmission } from '../utils/analytics.ts';
      const form = document.querySelector('#contact form');
      if (form instanceof HTMLFormElement) {
        populateUTMFields(form);
        form.addEventListener('submit', () => {
          populateUTMFields(form);
          trackFormSubmission(slug);
        });
      }
    </script>
  </body>
</html>
<style>
  @import '../styles/landing745.css';
  :global(body.landing-745) {
    background: #130f0d;
    color: #241b16;
  }
  .landing-745 main {
    overflow-x: hidden;
    background: #f6efe8;
  }

  /* ===== HERO DTBD VARIANT ===== */
  .hero745--dtbd { min-height: 100vh; }
  .hero745__container--dtbd {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: clamp(18px, 2.5vh, 28px);
    padding-top: clamp(40px, 5vh, 64px);
    padding-bottom: clamp(40px, 5vh, 64px);
    min-height: 100vh;
  }
  .hero745__toprow {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }
  .hero745__label--large {
    font-size: clamp(0.95rem, 1.3vw, 1.15rem);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,247,240,0.95);
    text-shadow: 0 1px 8px rgba(7,5,4,0.5);
  }
  .hero745__meta--toprow {
    font-size: clamp(0.82rem, 1vw, 0.98rem);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,220,180,0.85);
    text-shadow: 0 1px 8px rgba(7,5,4,0.5);
    padding-left: 20px;
    border-left: 2px solid rgba(255,200,140,0.35);
  }
  .hero745__h1--dtbd {
    font-size: clamp(2.4rem, 5vw, 5rem);
    line-height: 0.97;
    color: #fff8f2;
    max-width: 16ch;
    margin: 0;
    font-weight: 900;
  }
  .hero745__h1--dtbd em { display: inline-block; font-style: italic; color: #e9c8b6; }
  .hero745__triggers {
    display: flex;
    flex-direction: column;
    gap: clamp(8px, 1.2vh, 14px);
    max-width: 760px;
    padding: clamp(16px, 2vh, 22px) clamp(18px, 2.5vw, 26px);
    background: rgba(18,12,9,0.58);
    border: 1px solid rgba(255,247,240,0.14);
    border-radius: 18px;
    backdrop-filter: blur(14px);
  }
  .hero745__trigger {
    font-size: clamp(0.9rem, 1.2vw, 1.08rem);
    line-height: 1.55;
    color: rgba(255,247,240,0.9);
    margin: 0;
    padding-left: 16px;
    border-left: 3px solid rgba(233,200,182,0.55);
  }
  .hero745__actions--dtbd {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-top: 4px;
  }
  @media (max-width: 820px) {
    .hero745__toprow { flex-direction: column; align-items: flex-start; gap: 6px; }
    .hero745__meta--toprow { padding-left: 0; border-left: none; border-top: 1px solid rgba(255,200,140,0.3); padding-top: 6px; }
    .hero745__h1--dtbd { font-size: clamp(2rem, 8vw, 3.4rem); }
  }
  @media (max-width: 560px) {
    .hero745--dtbd, .hero745__container--dtbd { min-height: 100svh; }
    .hero745__h1--dtbd { font-size: clamp(1.8rem, 9vw, 2.8rem); }
    .hero745__trigger { font-size: 0.88rem; }
    .hero745__actions--dtbd { flex-direction: column; }
  }
</style>
