<!DOCTYPE html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{meta.title}</title>
    <meta name="description" content={meta.description} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@300;400;600;700&display=swap">
    <style is:global>
      :root {
        --color-dark-bg: #1a1a1a;
        --color-text-light: #f0f0f0;
        --color-gold-accent: #d4af37;
        --color-gray-text: #a0a0a0;
        --font-heading: 'Playfair Display', serif;
        --font-body: 'Inter', sans-serif;
      }

      body {
        margin: 0;
        font-family: var(--font-body);
        color: var(--color-text-light);
        background-color: var(--color-dark-bg);
        line-height: 1.6;
      }

      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 20px;
      }

      section {
        padding: 80px 0;
      }

      h1, h2, h3, h4, h5, h6 {
        font-family: var(--font-heading);
        color: var(--color-text-light);
        line-height: 1.2;
      }

      h1 {
        font-size: 3.5em;
        text-align: center;
        margin-bottom: 20px;
      }

      h2 {
        font-size: 2.5em;
        text-align: center;
        margin-bottom: 40px;
      }

      .text-center {
        text-align: center;
      }

      .gold-text {
        color: var(--color-gold-accent);
      }

      .hero-section {
        background-color: var(--color-dark-bg);
        color: var(--color-text-light);
        position: relative;
        overflow: hidden;
        padding: 120px 0;
      }

      .hero-content {
        position: relative;
        z-index: 2;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
      }

      .hero-image {
        width: 250px;
        height: 250px;
        border-radius: 50%;
        object-fit: cover;
        border: 3px solid var(--color-gold-accent);
        margin-bottom: 30px;
      }

      .hero-h1 {
        font-size: 4.5em;
        margin-bottom: 20px;
        text-shadow: 0 0 15px rgba(212, 175, 55, 0.5);
      }

      .hero-lead {
        font-size: 1.4em;
        max-width: 800px;
        margin-bottom: 40px;
        color: var(--color-gray-text);
      }

      .cta-button {
        display: inline-block;
        background-color: var(--color-gold-accent);
        color: var(--color-dark-bg);
        padding: 15px 40px;
        border-radius: 5px;
        text-decoration: none;
        font-weight: 600;
        font-size: 1.1em;
        transition: background-color 0.3s ease, transform 0.3s ease;
      }

      .cta-button:hover {
        background-color: #e0c26b;
        transform: translateY(-3px);
      }

      .trigger-points {
        background-color: #2a2a2a;
        padding: 60px 0;
      }

      .trigger-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 30px;
        margin-top: 40px;
      }

      .trigger-item {
        background-color: #333;
        padding: 30px;
        border-left: 3px solid var(--color-gold-accent);
        font-size: 1.1em;
        color: var(--color-gray-text);
      }

      .solution-section {
        background-color: var(--color-dark-bg);
      }

      .solution-h2 {
        color: var(--color-gold-accent);
        font-size: 2.8em;
        margin-bottom: 30px;
      }

      .solution-lead {
        font-size: 1.3em;
        max-width: 900px;
        margin: 0 auto 50px auto;
        color: var(--color-gray-text);
      }

      .solution-steps {
        display: flex;
        justify-content: space-around;
        gap: 30px;
        margin-top: 50px;
        flex-wrap: wrap;
      }

      .solution-step-item {
        flex: 1;
        min-width: 280px;
        background-color: #2a2a2a;
        padding: 30px;
        border-radius: 8px;
        text-align: center;
        border-bottom: 3px solid var(--color-gold-accent);
      }

      .solution-step-item h3 {
        color: var(--color-gold-accent);
        font-size: 1.5em;
        margin-bottom: 15px;
      }

      .solution-step-item p {
        color: var(--color-gray-text);
      }

      .book-section {
        background-color: #2a2a2a;
        padding: 100px 0;
      }

      .book-content {
        display: flex;
        align-items: center;
        gap: 50px;
        flex-wrap: wrap;
        justify-content: center;
      }

      .book-image-wrapper {
        flex-shrink: 0;
      }

      .book-image {
        width: 300px;
        height: auto;
        border: 5px solid var(--color-gold-accent);
        box-shadow: 0 0 20px rgba(212, 175, 55, 0.4);
      }

      .book-text {
        flex-grow: 1;
        max-width: 600px;
      }

      .book-text h2 {
        text-align: left;
        color: var(--color-gold-accent);
        margin-bottom: 20px;
      }

      .book-text blockquote {
        font-size: 1.4em;
        font-style: italic;
        color: var(--color-text-light);
        border-left: 4px solid var(--color-gold-accent);
        padding-left: 20px;
        margin: 30px 0;
      }

      .book-text footer {
        font-size: 1em;
        color: var(--color-gray-text);
      }

      .aha-moments-section {
        background-color: var(--color-dark-bg);
      }

      .aha-moment-card {
        display: flex;
        flex-direction: column;
        background-color: #2a2a2a;
        border-radius: 8px;
        overflow: hidden;
        margin-bottom: 40px;
      }

      .aha-moment-card img {
        width: 100%;
        height: 300px;
        object-fit: cover;
      }

      .aha-moment-card-content {
        padding: 30px;
      }

      .aha-moment-card h3 {
        color: var(--color-gold-accent);
        font-size: 1.8em;
        margin-bottom: 15px;
      }

      .aha-moment-card p {
        color: var(--color-gray-text);
        margin-bottom: 10px;
      }

      .aha-moment-insight {
        font-style: italic;
        color: var(--color-text-light);
        margin-top: 20px;
        border-top: 1px solid #444;
        padding-top: 20px;
      }

      .footer-section {
        background-color: #2a2a2a;
        padding: 60px 0;
        text-align: center;
      }

      .footer-cta {
        font-size: 1.8em;
        color: var(--color-text-light);
        margin-bottom: 30px;
      }

      .footer-copy {
        color: var(--color-gray-text);
        font-size: 0.9em;
      }
    </style>
  </head>
  <body>
    <main>
      <!-- Hero Section -->
      <section class="hero-section">
        <div class="container hero-content">
          <img src={images.hero} alt="Дамир Хайров" class="hero-image" />
          <h1 class="hero-h1"><span class="gold-text">Ваш опыт — это капитал.</span> Пора забрать его в собственность.</h1>
          <p class="hero-lead">Дамир Хайров — Архитектор персональной капитализации. Трансформируйте управленческий опыт в независимый актив и влияние на уровне Советов Директоров.</p>
          <a href="#contact" class="cta-button">Обсудить стратегию капитализации</a>
        </div>
      </section>

      <!-- Trigger Points -->
      <section class="trigger-points">
        <div class="container">
          <h2 class="text-center">Вы узнаете себя?</h2>
          <div class="trigger-grid">
            {triggerPoints.map((point: string) => (
              <div class="trigger-item" set:html={point}></div>
            ))}
          </div>
        </div>
      </section>

      <!-- Solution Section -->
      <section class="solution-section">
        <div class="container text-center">
          <h2 class="solution-h2">Архитектура персональной капитализации: трансформируйте ваш C-level опыт в независимый актив и влияние в Советах Директоров за 90 дней по методологии DTBD.</h2>
          <p class="solution-lead">Мы предлагаем полный цикл трансформации вашего управленческого опыта в независимый капитал и влияние.</p>
          <div class="solution-steps">
            <div class="solution-step-item">
              <h3>1. Аудит и Деконструкция Опыта</h3>
              <p>Глубинный анализ вашей карьеры для выявления уникальных компетенций и «нечестных преимуществ».</p>
            </div>
            <div class="solution-step-item">
              <h3>2. Упаковка Методологии и Бренда</h3>
              <p>Создание авторской методологии и стратегии личного бренда, позиционирующей вас как визионера.</p>
            </div>
            <div class="solution-step-item">
              <h3>3. Интеграция в Надсистему</h3>
              <p>Персональное сопровождение до получения первых контрактов в роли независимого директора или эдвайзера.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Book Section (Social Proof) -->
      <section class="book-section">
        <div class="container book-content">
          <div class="book-image-wrapper">
            <img src={images.aha3} alt="Книга Дамира Хайрова Что дальше?" class="book-image" />
          </div>
          <div class="book-text">
            <h2><span class="gold-text">«Что дальше?»</span> — Манифест вашей новой реальности</h2>
            <blockquote>
              «В основе моего подхода — методология Dreams To Be Done. Она позволяет топ-менеджеру сформулировать ту самую большую идею, которая превращает его из наемника в институцию».
            </blockquote>
            <footer>
              <strong>Дамир Хайров</strong> · Автор книги «Что дальше?», эксперт по стратегии
            </footer>
            <!-- Placeholder for logos if needed -->
          </div>
        </div>
      </section>

      <!-- Aha-Moments -->
      <section class="aha-moments-section">
        <div class="container">
          <h2 class="text-center">Как мы трансформируем ваш опыт в независимый капитал</h2>
          <div class="aha-moment-card">
            <img src={images.aha1} alt="Стратегическая сессия по выявлению суперсилы" />
            <div class="aha-moment-card-content">
              <h3>От «много умею» к «ядру ценности»</h3>
              <p><b>Барьер / Тревога:</b> «Я понимаю, что много умею, но не знаю, как выделить ядро своей ценности отдельно от компании».</p>
              <p><b>Визуализация Успеха:</b> Глубинный аудит вашего опыта для выявления «нечестного преимущества» и формирования авторской методологии. Результат — четкое понимание вашей уникальности, которую можно продавать рынку как независимый продукт.</p>
              <p class="aha-moment-insight"><i>Речевой инсайт: Ваша суперсила не в том, что вы делаете, а в том, как вы это делаете. Мы это оцифруем.</i></p>
            </div>
          </div>
          <div class="aha-moment-card">
            <img src={images.aha2} alt="Книга 'Что дальше?' как пример упаковки смыслов" />
            <div class="aha-moment-card-content">
              <h3>От «строчки в штатном расписании» к «лидеру мнений»</h3>
              <p><b>Барьер / Тревога:</b> «Меня знают как крутого профи внутри индустрии, но для внешнего рынка я — просто строчка в штатном расписании».</p>
              <p><b>Визуализация Успеха:</b> Создание системы влияния: от публикаций в Forbes до выступления на ПМЭФ с вашей авторской концепцией. Вы становитесь лидером мнений, чье видение (visionarism) генерирует входящие запросы от акционеров и инвесторов.</p>
              <p class="aha-moment-insight"><i>Речевой инсайт: Ваше имя должно работать на вас, а не только на корпорацию.</i></p>
            </div>
          </div>
          <div class="aha-moment-card">
            <img src={images.qualifier} alt="Визионерский взгляд на карьеру" />
            <div class="aha-moment-card-content">
              <h3>От «непонимания механики входа» к «первым контрактам в СД»</h3>
              <p><b>Барьер / Тревога:</b> «Я хочу в СД или эдвайзеринг, но не понимаю механику входа и как монетизировать свой опыт без операционки».</p>
              <p><b>Визуализация Успеха:</b> Персональное сопровождение до получения первых контрактов в роли независимого директора или эдвайзера. Готовый фреймворк перехода: от позиционирования для акционеров до структуры вашего эдвайзерингового бутика.</p>
              <p class="aha-moment-insight"><i>Речевой инсайт: Мы не ищем вам место, мы создаем его для вас.</i></p>
            </div>
          </div>
        </div>
      </section>

      <!-- Footer -->
      <section class="footer-section" id="contact">
        <div class="container">
          <h2 class="footer-cta">Архитектура персональной капитализации: трансформируйте ваш C-level опыт в независимый актив и влияние в Советах Директоров за 90 дней по методологии DTBD.</h2>
          <a href="#" class="cta-button">Обсудить стратегию капитализации</a>
          <p class="footer-copy">© 2026 Дамир Хайров. Все права защищены. Методология DTBD.</p>
        </div>
      </section>
    </main>
  </body>
</html>

---
const { slug, formName, meta, images, hero, triggerPoints, selfSelection, responseCards, lifeStages, processSteps, comparisons, sections, socialProof } = Astro.props;
---
