---
import Analytics from '../components/Analytics.astro';
import '../styles/global.css';

const slug = 'offer801';
const formName = 'offer801-repack-request';

const images = {
  hero: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/offer801-hero-clean-Lqy3vDEe5JDxTYL6dn5xSm.webp',
  aha1: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/offer801-courtyard-clean-KqDL6AqqXYREWP6gYVxE9T.webp',
  aha2: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/offer801-interior-clean-iWWvJJ96yaYAh4KrVnVRRa.webp',
  aha3: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/offer801-green-life-clean-dUMd5Atin3umGzTBnPyXSV.webp',
  qualifier: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/offer801-courtyard-clean-KqDL6AqqXYREWP6gYVxE9T.webp',
  compare: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/offer801-green-life-clean-dUMd5Atin3umGzTBnPyXSV.webp',
  evolution: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/offer801-interior-clean-iWWvJJ96yaYAh4KrVnVRRa.webp',
  footer: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/offer801-strategy-clean-E5MfcWKwwZcEvkEZgCTEGq.webp',
  currentPositioning: '/assets/offer801/current_positioning.webp',
};

const triggerPoints = [
  'Вы понимаете, что семье стало тесно не только в метраже, но и в самом качестве повседневной жизни.',
  'Вы хотите дом, где ребёнок, двор, зелень и спокойный ритм дня работают вместе, а не существуют как разрозненные обещания в рекламном буклете.',
  'Вы ищете более тихую и природную среду, но не готовы платить за неё выпадением из привычной городской логистики и семейных маршрутов.',
];

const responseCards = [
  {
    number: '01',
    title: 'Двор как продолжение квартиры',
    problem:
      '«Нам уже недостаточно просто новой квартиры. Нужна среда, где ребёнка не приходится постоянно выдёргивать из хаоса, машин, случайного окружения и тревоги родителей».',
    answer:
      'Сильнее всего проект звучит тогда, когда двор показывается не как галочка благоустройства, а как естественное продолжение семейной жизни. Здесь ребёнка можно отпускать не в абстрактно “красивое пространство”, а в понятную и более управляемую среду рядом с домом.',
    detail:
      'Тогда проект начинает продаваться не набором формальных преимуществ, а более ценной семейной свободой: меньше контроля, меньше бытовой тревоги, больше воздуха и более спокойный ритм дня.',
    cta: 'Посмотреть, как эту ценность можно упаковать в продающий оффер проекта',
    image: images.aha1,
    alt: 'Приватный семейный двор как продолжение квартиры',
  },
  {
    number: '02',
    title: 'Жизнь на вырост, а не метраж на время',
    problem:
      '«Мы не хотим переезжать просто ради пары дополнительных комнат и через несколько лет снова оказаться в той же тесноте, перегрузке и усталости».',
    answer:
      'Проект раскрывается тогда, когда обещает семье не временный бытовой апгрейд, а более устойчивую жизненную базу на годы вперёд. Больше воздуха, понятнее сценарии дома, меньше ощущения, что вся жизнь постоянно упирается в ограничения прежней квартиры.',
    detail:
      'Здесь важно продавать не квадратные метры сами по себе, а переход семьи в формат жизни, который выдерживает рост ребёнка, привычек, вещей и повседневных сценариев без нового цикла перегрузки.',
    cta: 'Обсудить, как показать семейный рост без штампов про простор и метры',
    image: images.aha2,
    alt: 'Светлый интерьер семейной квартиры как среда для жизни на вырост',
  },
  {
    number: '03',
    title: 'Природа без ощущения, что вы уехали из жизни',
    problem:
      '«Нам нужны зелень и спокойствие, но не хочется ради этого ломать логистику, терять связность с городом и постоянно чувствовать себя на отшибе».',
    answer:
      '“Дома у сада” можно показывать как зрелый баланс: проект не противопоставляет природную среду городской жизни, а собирает их в один более человеческий семейный режим. Жить становится мягче, но не приходится рвать маршруты, перестраивать день и выпадать из города.',
    detail:
      'Это снимает один из главных внутренних конфликтов семейного выбора: не выбирать между “по-человечески” и “удобно”, а получить обе ценности сразу в одном жизненном сценарии.',
    cta: 'Если в проекте есть сильная ценность, которую рынок пока не считывает, — обсудим переупаковку',
    image: images.aha3,
    alt: 'Зелёная семейная среда рядом с городом без ощущения удалённости',
  },
];

const selfSelection = [
  'Когда вы понимаете, что семье стало тесно не только в квартире, но и в самом устройстве дня.',
  'Когда вы хотите для ребёнка более понятную, зелёную и безопасную среду, а для себя — меньше трения в повседневной жизни.',
  'Когда вы ищете не просто новый адрес, а более собранный жизненный сценарий на годы вперёд.',
];

const comparisons = [
  {
    overline: 'Против generic family-коммуникации',
    title: 'Не “семейный ЖК”, а семейная жизнь с меньшим трением',
    text: 'Сила проекта — не в абстрактных словах про заботу о семье, а в более спокойном, зелёном и лучше организованном режиме повседневной жизни.',
  },
  {
    overline: 'Против продажи только метража',
    title: 'Не квадратные метры, а жизненный переход семьи',
    text: 'Переезд здесь нужно упаковывать как смену жизненного контура: больше воздуха, меньше усталости, более понятный быт и среда, которая выдерживает следующий семейный цикл.',
  },
  {
    overline: 'Против ложного выбора между городом и природой',
    title: 'Связность без шумной плотности',
    text: 'Проект выигрывает там, где показывает возможность жить мягче и зеленее, не разрывая привычную логику города, семейных маршрутов и рабочего ритма.',
  },
];

const lifeStages = [
  {
    stage: 'Стало тесно не только дома',
    price: 'JTBD stage 01',
    who: 'Семья чувствует, что старая квартира больше не выдерживает новый объём жизни: вещей, маршрутов, детских задач и усталости взрослых.',
    hire: 'Не просто больше метров, а ощущение, что дышать, собираться и жить стало заметно легче.',
    format: 'Переход от бытовой перегрузки к более устойчивой семейной базе.',
  },
  {
    stage: 'Нужен нормальный двор',
    price: 'JTBD stage 02',
    who: 'Родители начинают искать не квартиру отдельно, а среду, в которой ребёнок растёт спокойнее, а день семьи проходит с меньшим напряжением.',
    hire: 'Более предсказуемый и безопасный повседневный сценарий рядом с домом.',
    format: 'Проект как среда, а не просто жилой объект.',
  },
  {
    stage: 'Хотим жить мягче',
    price: 'JTBD stage 03',
    who: 'Семья уже не хочет шумной плотности, но и не готова к жизни, которая ощущается как отъезд из города и потеря связности.',
    hire: 'Баланс тишины, природы и обычной городской жизни без логистического разрыва.',
    format: 'Более человеческий режим дня без ощущения удалённости.',
  },
  {
    stage: 'Выбираем на годы вперёд',
    price: 'JTBD stage 04',
    who: 'Покупка рассматривается как следующий семейный этап, который должен выдержать рост ребёнка, привычек, быта и бытовых сценариев.',
    hire: 'Среду, которая не устареет через один жизненный цикл.',
    format: 'Квартира и проект как решение на вырост, а не временный компромисс.',
  },
];

const processSteps = [
  {
    number: '01',
    title: 'Вы оставляете контакты и ссылку на проект',
    text: 'Показываете текущий ЖК, лендинг или рекламную коммуникацию, которая не даёт нужной конверсии.',
  },
  {
    number: '02',
    title: 'Мы собираем гипотезу переупаковки',
    text: 'Смотрим сегмент, JTBD-напряжение, текущий оффер и архитектуру страницы, чтобы найти, где именно проект теряет силу.',
  },
  {
    number: '03',
    title: 'Проводим встречу по проекту',
    text: 'Показываем, как может выглядеть более точное позиционирование, структура лендинга и конверсионная логика без банальных девелоперских штампов.',
  },
  {
    number: '04',
    title: 'Фиксируем следующий шаг',
    text: 'Определяем, что делать дальше: корректировать сегмент, перепрошивать оффер или полностью пересобирать упаковку проекта.',
  },
];
---

<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>ЖК «Дома у сада» — более спокойная и зелёная семейная жизнь без выпадения из города</title>
    <meta
      name="description"
      content="Как показать ЖК «Дома у сада» не как ещё один семейный проект, а как понятный переход семьи в более спокойную, зелёную и устойчивую повседневную жизнь."
    />
  </head>
  <body class="landing-745">
    <Analytics landingSlug={slug} />

    <main>
      <section class="hero745 section section--photo-hero">
        <div class="hero745__backdrop" style={`--section-bg: url(${images.hero})`}></div>
        <div class="container hero745__container">
          <div class="hero745__label">Ак Барс Дом · ЖК «Дома у сада» · семья второго цикла</div>
          <div class="hero745__grid">
            <div class="hero745__content hero745__content--glass">
              <h1>Дом для семьи, которая уже переросла просто новую квартиру — <em>и теперь выбирает более спокойную, зелёную и собранную жизнь без выпадения из города.</em></h1>
              <p class="hero745__lead">
                «Дома у сада» — это проект для семей, которым стало тесно не только в старом метраже, но и в самом качестве повседневной жизни.
                Здесь ценность не в абстрактной “семейности”, а в более мягком ритме дня, понятном дворе, природном окружении и ощущении,
                что переезд действительно собирает жизнь заново — а не просто добавляет квадратные метры.
              </p>
              <p class="hero745__offer-line">Семейная среда · природное окружение · связность с городом</p>
              <div class="hero745__actions hero745__actions--stacked">
                <a class="button745 button745--primary" href="#contact">Показать вариант переупаковки проекта</a>
              </div>
            </div>

            <aside class="hero745__card hero745__card--floating">
              <div class="hero745__card-body">
                <h2>Семейный проект, который можно продавать не через шумные обещания, а через более устойчивый жизненный сценарий</h2>
                <p class="hero745__meta">Двор · Воздух · Баланс природы и города</p>
                <p>
                  Сильнее всего проект звучит тогда, когда говорит не о наборе преимуществ, а о переходе семьи в среду,
                  где каждый день становится чуть спокойнее, легче и лучше собран.
                </p>
              </div>
            </aside>
          </div>
        </div>
      </section>

      <section class="section section--tight triggers745-wrap triggers745-wrap--hero-continued">
        <div class="hero745__backdrop hero745__backdrop--continued" style={`--section-bg: url(${images.hero})`}></div>
        <div class="triggers745__tone"></div>
        <div class="container triggers745__container">
          <div class="triggers745">
            {triggerPoints.map((item) => <p>{item}</p>)}
          </div>
        </div>
      </section>

      <section class="immersive745 immersive745--hero" style={`--immersive-bg: url(${images.aha1})`}>
        <div class="container immersive745__inner">
          <div class="immersive745__card">
            <p class="immersive745__eyebrow">ЖК «Дома у сада» · семейная среда без лишнего шума</p>
            <h2>Когда проект перестаёт продаваться как набор семейных штампов и начинает собираться вокруг настоящей задачи семьи</h2>
            <p>
              В этом проекте важна не только эстетика. Важна точность попадания в напряжение аудитории: не обещать очередной “комфортный ЖК”,
              а показать семье среду, где можно жить спокойнее, зеленее и собраннее без ощущения, что ради этого нужно выпасть из города.
            </p>
            <div class="immersive745__facts">
              <span>Семья второго цикла</span>
              <span>Двор как сценарий жизни</span>
              <span>Природная среда рядом с городом</span>
              <span>Переезд как жизненный переход</span>
            </div>
          </div>
        </div>
      </section>

      <section class="section responses745 section--photo-soft" style={`--section-bg: url(${images.aha2})`}>
        <div class="responses745__veil"></div>
        <div class="container responses745__container">
          <div class="section745-heading center745 section745-heading--light">
            <h2>Как «Дома у сада» отвечает на то, что по-настоящему останавливает семью</h2>
          </div>
          <div class="responses745__stack">
            {responseCards.map((card) => (
              <article class="response745-card">
                <div class="response745-card__media">
                  <img src={card.image} alt={card.alt} loading="lazy" />
                </div>
                <div class="response745-card__body">
                  <div class="response745-card__number">{card.number}</div>
                  <h3>{card.title}</h3>
                  <p class="response745-card__problem">{card.problem}</p>
                  <p>{card.answer}</p>
                  <p class="response745-card__detail">{card.detail}</p>
                  {card.cta && (
                    <a class="inline-link745" href="#contact">{card.cta}</a>
                  )}
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="split-photo745">
        <div class="split-photo745__image" style={`--split-bg: url(${images.qualifier})`}></div>
        <div class="split-photo745__content-wrap">
          <div class="container split-photo745__container">
            <div class="split-photo745__content">
              <p class="immersive745__eyebrow">ЖК «Дома у сада» · Узнайте себя</p>
              <h2>Этот проект — для семьи, которая уже не хочет жить в режиме постоянного бытового трения</h2>
              <div class="self745 self745--transparent">
                {selfSelection.map((item) => <p>{item}</p>)}
              </div>
              <blockquote class="quote745 quote745--light">
                <p>
                  «Сильные семейные проекты продаются не через обещания “счастливой жизни”, а через более точное ощущение,
                  что ежедневная жизнь семьи действительно становится тише, мягче и лучше собрана».
                </p>
                <footer>Стратегия переупаковки девелоперского продукта</footer>
              </blockquote>
              <a class="inline-link745 inline-link745--light" href="#contact">Если ваш продукт сильнее, чем его текущая упаковка — обсудим это на встрече</a>
            </div>
          </div>
        </div>
      </section>

      <section class="immersive745 immersive745--contrast" style={`--immersive-bg: url(${images.aha3})`}>
        <div class="container immersive745__inner immersive745__inner--right">
          <div class="immersive745__card immersive745__card--single-story">
            <div class="story745-card">
              <div class="story745-card__number">03</div>
              <h2>Природа без ощущения, что вы выпали из жизни</h2>
              <p class="story745-card__problem">«Мы хотим более зелёную и спокойную среду, но не готовы платить за это потерей связности с городом, маршрутами и нормальным семейным ритмом».</p>
              <p>Проект становится сильнее, когда показывает не компромисс, а зрелый баланс: семья получает воздух, двор, зелень и более тихий ритм, не вырывая себя из привычной логистики, работы, школы и обычной городской жизни.</p>
              <a class="inline-link745" href="#contact">Если у вашего проекта есть ценность, которую рынок пока не считывает — давайте это разберём</a>
            </div>
          </div>
        </div>
      </section>

      <section class="section life745 section--photo-soft" style={`--section-bg: url(${images.evolution})`}>
        <div class="responses745__veil responses745__veil--warm"></div>
        <div class="container life745__container">
          <div class="section745-heading center745 section745-heading--light section745-heading--max">
            <h2>На каком этапе семейного цикла клиент выбирает ваш продукт?</h2>
            <p>Эта таблица показывает не ассортимент, а логику того, как жизненная ситуация семьи, её напряжение и Core Job соединяются в осмысленное позиционирование.</p>
          </div>
          <div class="life745-table-wrap">
            <table class="life745-table">
              <thead>
                <tr>
                  <th>Этап</th>
                  <th>Кто семья сейчас</th>
                  <th>Что она нанимает</th>
                  <th>Как это упаковывать</th>
                </tr>
              </thead>
              <tbody>
                {lifeStages.map((item) => (
                  <tr>
                    <td>
                      <strong>{item.stage}</strong>
                      <span>{item.price}</span>
                    </td>
                    <td>{item.who}</td>
                    <td>{item.hire}</td>
                    <td>{item.format}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <div class="center745 action745-wrap">
            <a class="button745 button745--ghost" href="#contact">Обсудить, как упаковать семейный ЖК под реальный сценарий жизни клиента</a>
          </div>
        </div>
      </section>

      <section class="section compare745 section--contrast">
        <div class="compare745__backdrop" style={`--compare-bg: url(${images.compare})`}></div>
        <div class="container compare745__container">
          <div class="section745-heading section745-heading--light section745-heading--max">
            <p class="section745-heading__eyebrow">Почему такой оффер выигрывает</p>
            <h2>Как «Дома у сада» может выглядеть сильнее на фоне типовых конкурентов</h2>
          </div>
          <div class="compare745__grid">
            {comparisons.map((item) => (
              <article class="compare745-card">
                <p class="compare745-card__eyebrow">{item.overline}</p>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="section process745 section--photo-band" style={`--section-bg: url(${images.footer})`}>
        <div class="section-band745__overlay section-band745__overlay--dark"></div>
        <div class="container process745__container">
          <div class="section745-heading center745 section745-heading--light section745-heading--max">
            <h2>Как проходит путь к переупаковке девелоперского продукта</h2>
          </div>
          <div class="process745__grid process745__grid--stacked">
            {processSteps.map((step) => (
              <article class="process745-card process745-card--light process745-card--stacked">
