---
import Analytics from '../components/Analytics.astro';
import '../styles/global.css';

const slug = 'template-aesthetes';
const formName = 'template-aesthetes-repack-request';

// ─── ПЕРЕМЕННЫЕ ДЛЯ АДАПТАЦИИ ────────────────────────────────────────────────
const projectName = 'ЖК «[PROJECT_NAME]»';
const developerName = '[DEVELOPER_NAME]';
const districtContext = '[CITY_OR_DISTRICT]';
const architecturalProof = '[ARCHITECTURAL_PROOF]';
const environmentProof = '[ENVIRONMENT_PROOF]';
const materialProof = '[MATERIAL_PROOF]';

const proofBullets = [
  'Архитектура, на которую приятно смотреть не только на рендерах',
  'Среда, в которой можно замедлиться, а не только пройти через неё',
  'Материалы и детали, которые поддерживают ощущение качества каждый день',
  'Более тихая и собранная повседневность без лишнего визуального напряжения',
];

const images = {
  hero: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/aesthetes-hero-facade.webp',
  aha1: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/aesthetes-facade-detail.webp',
  aha2: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/aesthetes-courtyard.webp',
  aha3: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/aesthetes-lobby-light.webp',
  qualifier: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/aesthetes-materials-collage.webp',
  footer: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/aesthetes-evening-interior.webp',
  currentPositioning: '/assets/template-aesthetes/current_positioning_user.webp',
};

// ─── БЛОК 2: ТРИГГЕРЫ ────────────────────────────────────────────────────────
const triggerPoints = [
  'Слишком много домов вокруг выглядят так, будто с вами разговаривают слишком громко.',
  'Безликость утомляет не меньше, чем плохая планировка.',
  'Хочется не роскоши, а среды, в которой приятно жить долго.',
];

// ─── БЛОК 4: AHA-МОМЕНТЫ ─────────────────────────────────────────────────────
const responseCards = [
  {
    number: '01',
    title: 'Фасад, который не надоедает через полгода',
    problem:
      'Большинство проектов пытаются произвести впечатление в момент продажи. Но человек с насмотренностью быстро замечает, когда архитектура кричит вместо того, чтобы говорить.',
    answer:
      `Если у ${projectName} есть ${architecturalProof}, это можно показать как редкое качество: дом не пытается кричать о себе, но обладает архитектурной силой, которую приятно считывать годами.`,
    detail:
      'Такая архитектура не устаревает эмоционально — она становится точнее и спокойнее с каждым годом проживания.',
    cta: '',
    image: images.aha1,
    alt: 'Архитектурная деталь фасада с чистыми линиями и качественными материалами',
  },
  {
    number: '02',
    title: 'Двор, где нет визуальной истерики',
    problem:
      'Когда благоустройство сделано формально — оно видно сразу. Пластик, случайные малые формы, перегруженность деталями или, наоборот, пустота без сценариев.',
    answer:
      `Через ${environmentProof} проект можно раскрыть как более деликатную и уважительную среду: место, где есть воздух, мера, сценарии спокойного присутствия и ощущение, что пространство собрано для жизни, а не только для продажи.`,
    detail:
      'Именно такой двор становится аргументом для тех, кто устал от визуального шума и ищет место, где можно просто быть.',
    cta: '',
    image: images.aha2,
    alt: 'Спокойный двор с продуманным благоустройством и зелёными зонами',
  },
  {
    number: '03',
    title: 'Качество, которое видно не по словам, а по тому, как всё решено',
    problem:
      'Слово «качество» стало настолько общим, что перестало что-либо значить. Для этого сегмента важны не обещания, а конкретные решения: как собраны входные группы, что происходит в лобби, как работает свет.',
    answer:
      `Если у ${projectName} сильны входные группы, лобби, навигация, ${materialProof} или свет, это должно прозвучать как доказательство зрелого подхода.`,
    detail:
      'Хороший дом узнаётся не по обещаниям, а по тому, как он собран в деталях.',
    cta: '',
    image: images.aha3,
    alt: 'Лобби с качественными материалами, продуманным светом и чувством меры',
  },
];

// ─── БЛОК 5: САМООТБОР ───────────────────────────────────────────────────────
const selfSelection = [
  `${projectName} имеет смысл переупаковывать именно для тех, кто не ищет показного статуса и не выбирает жильё как демонстрацию успеха.`,
  'Это выбор для людей, которым важно, чтобы среда не утомляла, не раздражала деталями и не хотелось всё время что-то мысленно исправлять.',
  'Если человек устал от визуального шума и ищет дом, в котором можно жить долго без эмоционального износа, этот сегмент узнаёт себя почти сразу.',
  '«Не роскошь, а среда, в которой приятно жить долго».',
];

// ─── БЛОК 7: ШАГИ ПРОЦЕССА ───────────────────────────────────────────────────
const processSteps = [
  {
    number: '01',
    title: 'Смотрим текущую подачу',
    text: 'Находим, где проект говорит слишком общо и теряет свою архитектурную и средовую ценность.',
  },
  {
    number: '02',
    title: 'Проверяем сегмент',
    text: 'Определяем, действительно ли проект подходит для эстетов и средофилов — и насколько его реальные качества совпадают с запросом сегмента.',
  },
  {
    number: '03',
    title: 'Собираем новую подачу',
    text: 'Переводим язык фасада, двора, материалов и тишины в narrative покупки — без пустых эстетических обещаний.',
  },
  {
    number: '04',
    title: 'Показываем готовую страницу',
    text: 'Передаём лендинг, который уже можно использовать как новую точку коммуникации с этим сегментом.',
  },
];
---

<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{projectName} — пространство, которое не спорит с вашим вкусом</title>
    <meta
      name="description"
      content={`Показываем, как ${projectName} можно раскрыть как редкий для ${districtContext} дом, в котором архитектура и среда не спорят с жизнью, а собирают её спокойнее и точнее.`}
    />
  </head>
  <body class="landing-745">
    <Analytics landingSlug={slug} />

    <main>
      <!-- БЛОК 1: HERO -->
      <section class="hero745 section section--photo-hero">
        <div class="hero745__backdrop" style={`--section-bg: url(${images.hero})`}></div>
        <div class="container hero745__container">
          <div class="hero745__label">Жить среди красивого — не роскошь, а нормальная потребность</div>
          <div class="hero745__grid">
            <div class="hero745__content hero745__content--glass">
              <h1>Пространство, которое не спорит с вашим вкусом</h1>
              <p class="hero745__lead">
                Есть проекты, которые решают вопрос адреса. А есть проекты, которые меняют само качество повседневности. {projectName} можно почувствовать именно так: как место, где архитектура, тишина, материалы и среда собираются в более спокойную, цельную и достойную жизнь.
              </p>
              <p class="hero745__offer-line">Это важно для тех, кто устал от визуального шума и ощущения, что даже хорошее жильё слишком часто выглядит случайным</p>
              <div class="hero745__actions hero745__actions--stacked">
                <a class="button745 button745--primary" href="#contact">посмотреть предложение</a>
              </div>
            </div>

            <aside class="hero745__card hero745__card--floating">
              <div class="hero745__card-body">
                <h2>{projectName} — дом для тех, кому важно не только где жить, но и как ощущается сама среда жизни</h2>
                <p class="hero745__meta">Ценность считывается не через крик, а через такт, собранность и удовольствие быть в этом пространстве каждый день</p>
                <p>
                  Здесь можно показать не «ещё один premium-объект», а место, где человеку становится просто легче жить.
                </p>
              </div>
            </aside>
          </div>
        </div>
      </section>

      <!-- БЛОК 2: ТРИГГЕРЫ -->
      <section class="section section--tight triggers745-wrap triggers745-wrap--hero-continued">
        <div class="hero745__backdrop hero745__backdrop--continued" style={`--section-bg: url(${images.hero})`}></div>
        <div class="triggers745__tone"></div>
        <div class="container triggers745__container">
          <div class="triggers745">
            {triggerPoints.map((item) => <p>{item}</p>)}
          </div>
        </div>
      </section>

      <!-- БЛОК 3: ГОТОВОЕ РЕШЕНИЕ (REFRAMING) -->
      <section class="immersive745 immersive745--hero" style={`--immersive-bg: url(${images.aha1})`}>
        <div class="container immersive745__inner">
          <div class="immersive745__card">
              <p class="immersive745__eyebrow">{projectName} · сценарий «эстеты и средофилы»</p>
              <h2>{projectName} — редкий для {districtContext} дом, в котором архитектура и среда не спорят с жизнью</h2>
              <p class="immersive745__body immersive745__body--light">
                Если в проекте действительно есть {architecturalProof}, {environmentProof} и ощущение такта в общих пространствах, его можно показать не как «ещё один premium-объект», а как место, где человеку становится просто легче жить.
              </p>
              <p class="immersive745__body immersive745__body--light">
                Здесь ценность не в том, чтобы впечатлить на пять минут. Ценность в том, чтобы через год, три и пять лет дом не утомлял, не устаревал эмоционально и продолжал ощущаться как точный выбор.
              </p>
              <div class="immersive745__facts">
                {proofBullets.map((proof) => <span>{proof}</span>)}
              </div>
              <p class="immersive745__bridge immersive745__bridge--light">Для этого сегмента особенно важно одно: проект должен не обещать красивую жизнь, а доказывать, что в нём уже заложена более тихая, цельная и достойная повседневность.</p>
          </div>
        </div>
      </section>

      <!-- БЛОК 4: AHA-МОМЕНТЫ -->
      <section class="section responses745 section--photo-soft" style={`--section-bg: url(${images.aha2})`}>
        <div class="responses745__veil"></div>
        <div class="container responses745__container">
          <div class="section745-heading center745 section745-heading--light">
            <h2>Три причины, почему этот сегмент может узнать себя в проекте</h2>
          </div>
          <div class="responses745__stack">
            {responseCards.map((card) => (
              <article class="response745-card">
                <div class="response745-card__media">
                  <img src={card.image} alt={card.alt} loading="lazy" />
                </div>
                <div class="response745-card__body">
                  <div class="response745-card__number">{card.number}</div>
                  <h3>{card.title}</h3>
                  <p class="response745-card__problem">{card.problem}</p>
                  <p>{card.answer}</p>
                  <p class="response745-card__detail">{card.detail}</p>
                  {card.cta && (
                    <a class="inline-link745" href="#contact">{card.cta}</a>
                  )}
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <!-- БЛОК 5: САМООТБОР -->
      <section class="split-photo745">
        <div class="split-photo745__image" style={`--split-bg: url(${images.qualifier})`}></div>
        <div class="split-photo745__content-wrap">
          <div class="container split-photo745__container">
            <div class="split-photo745__content">
              <p class="immersive745__eyebrow">{projectName} · самоотбор сегмента</p>
              <h2>Это ощущение возникает не из воздуха. У него есть конкретные основания.</h2>
              <div class="self745 self745--transparent self745--light">
                {selfSelection.map((item) => <p>{item}</p>)}
              </div>
              <blockquote class="quote745 quote745--light">
                <p>
                  «Не роскошь, а среда, в которой приятно жить долго».
                </p>
                <footer>Сегмент «эстеты и средофилы»</footer>
              </blockquote>
            </div>
          </div>
        </div>
      </section>

      <!-- БЛОК 6: B2B РАЦИОНАЛЬНОСТЬ -->
      <section class="immersive745 immersive745--contrast" style={`--immersive-bg: url(${images.aha3})`}>
        <div class="container immersive745__inner immersive745__inner--right">
          <div class="immersive745__card immersive745__card--single-story">
            <div class="story745-card story745-card--light-copy">
              <div class="story745-card__number">06</div>
              <h2>«Эстеты и средофилы» — это не просто люди, которым «нравится дизайн». Это отдельная логика выбора жилья.</h2>
              <p class="story745-card__problem">Они не ищут показного статуса. Они ищут дом, в котором не устают глаза, не раздражают детали и не хочется всё время что-то мысленно исправлять. Если проект действительно силён средой и архитектурой, его нужно показывать не общим premium-языком, а через более точный сценарий выбора.</p>
              <a class="inline-link745 inline-link745--light" href="#contact">Посмотреть, как этот сценарий упаковать для вашего проекта</a>
            </div>
          </div>
        </div>
      </section>

      <!-- БЛОК 7: ПРОЦЕСС РАБОТЫ -->
      <section class="section process745 section--photo-band" style={`--section-bg: url(${images.footer})`}>
        <div class="section-band745__overlay section-band745__overlay--dark"></div>
        <div class="container process745__container">
          <div class="section745-heading center745 section745-heading--light section745-heading--max">
            <h2>Покажем, как превратить скрытую силу проекта в считываемую страницу для правильного сегмента</h2>
            <p>Итогом становится не абстрактная стратегия, а готовая страница, где человек считывает проект через ту ценность, которая действительно может стать причиной выбора.</p>
          </div>
          <div class="process745__grid process745__grid--stacked">
            {processSteps.map((step) => (
              <article class="process745-card process745-card--light process745-card--stacked">
                <div class="process745-card__number">{step.number}</div>
                <h3>{step.title}</h3>
                <p>{step.text}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <!-- БЛОК 8: СКРИНШОТ + ФОРМА -->
      <section id="contact" class="section final745 final745--photo">
        <div class="final745__backdrop" style={`--final-bg: url(${images.footer})`}></div>
        <div class="container final745__container">
          <div class="final745__layout">
            <div class="final745__media-copy">
              <p class="final745__eyebrow">Текущий пример позиционирования проекта</p>
              <h2>Если текущее позиционирование не приводит к продажам — покажем, как может выглядеть переупаковка {projectName} под сегмент «эстеты и средофилы»</h2>

              <div class="final745__positioning-shot">
                <img src={images.currentPositioning} alt={`Текущее позиционирование ${projectName}`} loading="lazy" />
              </div>
            </div>
            <div class="final745__card">
              <p class="final745__eyebrow final745__eyebrow--dark">Стратегическая встреча по переупаковке</p>
              <form
                name={formName}
                method="POST"
                data-netlify="true"
                netlify-honeypot="bot-field"
                action="/thank-you"
                class="final745__form"
              >
                <input type="hidden" name="form-name" value={formName} />
                <input type="hidden" name="landing_slug" value={slug} />
                <input type="hidden" name="utm_source" value="" />
                <input type="hidden" name="utm_medium" value="" />
                <input type="hidden" name="utm_campaign" value="" />
                <input type="hidden" name="utm_content" value="" />
                <input type="hidden" name="utm_term" value="" />

                <p class="sr-only">
                  <label>
                    Не заполняйте это поле, если вы человек:
                    <input name="bot-field" />
                  </label>
                </p>

                <div class="final745__form-grid">
                  <div class="final745__field-block">
                    <label for="name" class="field-label745">Имя</label>
                    <input type="text" id="name" name="name" required class="field-input745" />
                  </div>

                  <div class="final745__field-block final745__form-full">
                    <label for="phone" class="field-label745">Телефон / Telegram</label>
                    <input type="tel" id="phone" name="phone" required class="field-input745" />
                  </div>

                  <div class="final745__field-block final745__form-full">
                    <label for="email" class="field-label745">Email</label>
                    <input type="email" id="email" name="email" required class="field-input745" />
                  </div>
                </div>

                <button type="submit" class="button745 button745--primary final745__submit">
                  записаться на встречу
                </button>
              </form>
            </div>
          </div>
        </div>
      </section>
    </main>

    <script define:vars={{ slug }}>
      import { populateUTMFields, trackFormSubmission } from '../utils/analytics.ts';

      const form = document.querySelector('#contact form');

      if (form instanceof HTMLFormElement) {
        populateUTMFields(form);
        form.addEventListener('submit', () => {
          populateUTMFields(form);
          trackFormSubmission(slug);
        });
      }
    </script>
  </body>
</html>

<style>
  :global(body.landing-745) {
    background: #130f0d;
    color: #241b16;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif;
  }

  .landing-745 main {
    overflow-x: hidden;
    background: #f6efe8;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif;
    color: #fff8f2;
  }

  .landing-745 h1,
  .landing-745 h2,
  .landing-745 h3,
  .landing-745 h4,
  .landing-745 h5,
  .landing-745 h6,
  .landing-745 p,
  .landing-745 a,
  .landing-745 span,
  .landing-745 label,
  .landing-745 input,
  .landing-745 textarea,
  .landing-745 button,
  .landing-745 th,
  .landing-745 td,
  .landing-745 blockquote,
  .landing-745 li {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif;
  }

  .section { position: relative; }

  .hero745, .final745, .responses745, .process745 { position: relative; }

  .hero745__container, .responses745__container, .process745__container, .final745__container {
    position: relative;
    z-index: 2;
  }

  .section--photo-hero, .section--photo-band, .section--photo-soft, .final745--photo {
    background-image: var(--section-bg);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .hero745 {
    min-height: clamp(760px, 92vh, 980px);
    display: flex;
    align-items: stretch;
    padding: 36px 0 28px;
    overflow: hidden;
  }

  .hero745__backdrop {
    position: absolute;
    inset: 0;
    background-image: linear-gradient(120deg, rgba(17, 12, 9, 0.82), rgba(17, 12, 9, 0.38)), var(--section-bg);
    transform: scale(1.04);
    transform-origin: center;
    background-size: cover;
    background-position: center;
  }

  .hero745__backdrop--continued {
    background-image: linear-gradient(180deg, rgba(17, 12, 9, 0.3), rgba(17, 12, 9, 0.72)), var(--section-bg);
  }

  .hero745__container {
    display: flex;
    flex-direction: column;
    gap: 18px;
    justify-content: center;
    padding-top: clamp(88px, 10vh, 120px);
    min-height: clamp(700px, calc(92vh - 64px), 900px);
  }

  .hero745__label, .hero745__offer-line, .immersive745__eyebrow, .final745__eyebrow, .hero745__meta {
    font-size: 0.82rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 244, 232, 0.9);
  }

  .hero745__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.28fr) minmax(280px, 0.72fr);
    gap: 28px;
    align-items: start;
  }

  .hero745__content {
