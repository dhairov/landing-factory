---
import Analytics from '../components/Analytics.astro';
import '../styles/global.css';

const slug = 'endemik-established';
const formName = `landing-${slug}`;

const images = {
  hero: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/endemik-hero-soft-editorial-jZ2RnsKjd9NSrr4j9QMdwi.webp',
  aha1: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/endemik-lobby-soft-editorial-ED4iiTxvtQsxvcJ7eUdNnq.webp',
  aha2: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/endemik-courtyard-soft-editorial-jNjAHDps6dwQrL7PbDAV4S.webp',
  aha3: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/endemik-terrace-soft-editorial-ZM2X5U9oLLpsWvUNEtZLMC.webp',
  qualifier: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/endemik-courtyard-soft-editorial-jNjAHDps6dwQrL7PbDAV4S.webp',
  compare: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/endemik-night-facade-soft-editorial-LGNeq4BizQaXcdigvCRGXr.webp',
  evolution: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/endemik-terrace-soft-editorial-ZM2X5U9oLLpsWvUNEtZLMC.webp',
  footer: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/endemik-night-facade-soft-editorial-LGNeq4BizQaXcdigvCRGXr.webp',
  currentPositioning: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/pasted_file_EVKaGJ_изображение_5b7ef669.webp',
};

const triggerPoints = [
  'Вы давно можете позволить себе хорошее жильё, но большинство проектов в центре выглядят либо слишком шумно, либо слишком демонстративно.',
  'Вам нужен дом, где архитектура, приватность и адрес работают вместе — без ощущения, что вы покупаете статус напоказ.',
  'Выбирая квартиру, вы фактически выбираете способ жить: в тишине, в собранном ритме и без чужого сценария за стеной.',
];

const responseCards = [
  {
    number: '01',
    title: 'Не шумный адрес, а дом с правильной дистанцией',
    problem:
      'В центре легко найти эффектный фасад, но гораздо сложнее — дом, в котором действительно спокойно возвращаться к себе каждый день.',
    answer:
      'Эндемик раскрывается как камерный бизнес-класс с тихим характером: сдержанная архитектура, продуманная приватность и ощущение личной территории без лишнего внимания со стороны.',
    detail:
      'Здесь ценность не в громких обещаниях, а в том, что дом поддерживает ваш ритм жизни и не заставляет подстраиваться под чужой сценарий.',
    image: images.aha1,
    alt: 'Тихое и элегантное лобби ЖК Эндемик без визуального шума',
    cta: 'Посмотреть, как устроена приватность',
  },
  {
    number: '02',
    title: 'Центр, в котором удобно жить, а не только приезжать по делам',
    problem:
      'Даже в хорошей локации можно быстро устать от шума, плотного трафика и ощущения, что город всё время требует от вас темпа.',
    answer:
      'Поэтому важен не просто адрес, а то, как он работает на ваше ежедневное удобство: короткие маршруты, привычная инфраструктура и дом, где после города остаётся чувство собранности, а не перегруза.',
    detail:
      'Эндемик предлагает редкий баланс: быть в центре событий и при этом сохранять собственную дистанцию и комфортный темп жизни.',
    image: images.aha2,
    alt: 'Приватный внутренний двор ЖК Эндемик для спокойной городской жизни',
    cta: 'Оценить ритм жизни в проекте',
  },
  {
    number: '03',
    title: 'Архитектура, которая говорит о вкусе без лишней демонстрации',
    problem:
      'Если вам близка спокойная эстетика, крикливый премиум быстро начинает утомлять — в нём слишком много демонстрации и слишком мало настоящего комфорта.',
    answer:
      'В Эндемике материалы, пропорции и общий ритм дома складываются в ощущение зрелого выбора: дом выглядит достойно, но не спорит с человеком и не требует постоянного подтверждения статуса.',
    detail:
      'Такой проект легко представить не как витрину, а как своё пространство — точное, красивое и естественное для жизни каждый день.',
    image: images.aha3,
    alt: 'Панорамная терраса и спокойная эстетика взрослого выбора в ЖК Эндемик',
    cta: 'Оставить заявку',
  },
];

const selfSelection = [
  'Вы больше не хотите выбирать жильё по чужим критериям успеха — вам важнее совпадение с собственным ритмом, а не внешний шум вокруг проекта.',
  'Для вас тишина, приватность и архитектурная собранность важнее, чем громкие обещания и показной статус.',
  'Вы ищете дом, в котором комфорт ощущается не как набор опций, а как естественная среда для взрослой самостоятельной жизни.',
];

const comparisons = [
  {
    overline: 'Вместо типового бизнес-класса',
    title: 'Сдержанная архитектура вместо универсального глянца',
    text:
      'Эндемик привлекает не показной роскошью, а внутренней собранностью. Такой дом воспринимается благороднее, потому что в нём нет ничего лишнего — только точная эстетика и чувство меры.',
  },
  {
    overline: 'Вместо крикливого премиума',
    title: 'Приватность, которую ощущаешь каждый день',
    text:
      'Для личного комфорта важны не только квадратные метры и статус адреса, но и ощущение, что дом не давит плотностью, шумом и лишним вниманием. Здесь ценность считывается на уровне атмосферы.',
  },
  {
    overline: 'Вместо массовой застройки',
    title: 'Личный масштаб вместо ощущения общего потока',
    text:
      'Камерный дом выигрывает тем, что в нём проще почувствовать себя на месте: меньше случайного движения, больше порядка, больше внутреннего покоя и ясности в ежедневной жизни.',
  },
];

const lifeStages = [
  {
    stage: 'Редкий формат',
    price: 'Фокус коммуникации',
    who: 'Для самостоятельного взрослого человека, который выбирает не просто квартиру, а среду, совпадающую с его внутренним ритмом.',
    hire: 'Не демонстративный статус, а приватность, тишину, архитектурную собранность и ощущение личной территории.',
    format: 'Дом как точное совпадение со зрелым способом жить.',
  },
  {
    stage: 'Город без давления',
    price: 'Фокус локации',
    who: 'Для тех, кто хочет остаться в активном городском контексте, но не готов жить в атмосфере проходного двора и постоянного внешнего шума.',
    hire: 'Контроль над своим маршрутом, удобство центра и дистанцию от хаоса.',
    format: 'Локация как часть личного комфорта, а не как банальный плюс в списке.',
  },
  {
    stage: 'Зрелый вкус',
    price: 'Фокус эстетики',
    who: 'Для покупателей, которым уже не нужно ничего доказывать рынку, окружению или самим себе.',
    hire: 'Дом, который подтверждает вкус не криком, а правильной интонацией, материалом и ритмом.',
    format: 'Архитектура как отражение характера, а не как декоративная оболочка.',
  },
  {
    stage: 'Повод оставить заявку',
    price: 'Фокус CTA',
    who: 'Для человека, который должен узнать в проекте не «ещё один хороший ЖК», а именно своё будущее пространство жизни.',
    hire: 'Понять, насколько дом совпадает с его личным сценарием и ожиданием от среды.',
    format: 'Переход от красивого просмотра к предметному интересу и заявке.',
  },
];

const processSteps = [
  {
    number: '01',
    title: 'Тишина вместо лишнего шума',
    description:
      'Камерный формат, продуманная приватность и спокойный характер дома помогают быстрее почувствовать, что здесь можно жить в своём ритме, а не в навязанном темпе большого города.',
  },
  {
    number: '02',
    title: 'Центр без перегруза',
    description:
      'Локация работает на повседневное удобство: привычные маршруты остаются короткими, а дом сохраняет дистанцию от городского давления и суеты.',
  },
  {
    number: '03',
    title: 'Эстетика, которая не устаревает',
    description:
      'Сдержанная архитектура, материалы и общий ритм пространства делают проект выбором для тех, кто ценит не громкий эффект, а долгую внутреннюю уверенность в своём решении.',
  },
];
---

<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>ЖК «Эндемик» — камерный бизнес-класс в центре Краснодара</title>
    <meta
      name="description"
      content="ЖК «Эндемик» — камерный бизнес-класс в центре Краснодара: приватность, спокойная архитектура, взрослый городской ритм и дом для тех, кто выбирает тишину без компромиссов."
    />
  </head>
  <body class="landing-745">
    <Analytics landingSlug={slug} />

    <main>
      <section class="hero745 section section--photo-hero hero745--dtbd">
        <div class="hero745__backdrop" style={`--section-bg: url(${images.hero})`}></div>
        <div class="container hero745__container hero745__container--dtbd">
          <div class="hero745__toprow">
            <span class="hero745__label hero745__label--large">ЖК «Эндемик» · Краснодар · Бизнес-класс</span>
            <span class="hero745__meta hero745__meta--toprow">Камерный масштаб · Спокойная эстетика · Приватная атмосфера</span>
          </div>
          <h1 class="hero745__h1--dtbd">Дом для тех, кто выбирает <em>тишину, приватность и спокойную архитектуру в центре города.</em></h1>
          <div class="hero745__triggers">
            {triggerPoints.map((item) => <p class="hero745__trigger">{item}</p>)}
          </div>
          <div class="hero745__actions hero745__actions--dtbd">
            <a class="button745 button745--primary" href="#contact">Ознакомиться с предложением</a>
          </div>
        </div>
      </section>

      <section class="immersive745 immersive745--hero" style={`--immersive-bg: url(${images.aha1})`}>
        <div class="container immersive745__inner">
          <div class="immersive745__card">
            <p class="immersive745__eyebrow">ЖК «Эндемик» · Право на свой ритм</p>
            <h2>Когда проект перестаёт продаваться как набор характеристик и начинает собираться вокруг подлинной задачи клиента</h2>
            <p>
              В этом проекте важна не только эстетика. Важна точность попадания в напряжение аудитории: не показать статус,
              а дать человеку пространство, где можно жить в тишине, приватности и внутреннем масштабе.
            </p>
            <div class="immersive745__facts">
              <span>Приватный формат для взрослой аудитории</span>
              <span>Спокойный городской ритм</span>
              <span>Архитектура без визуального шума</span>
              <span>Дом для самостоятельных и состоявшихся</span>
            </div>
          </div>
        </div>
      </section>

      <section class="section responses745 section--photo-soft" style={`--section-bg: url(${images.aha2})`}>
        <div class="responses745__veil"></div>
        <div class="container responses745__container">
          <div class="section745-heading center745 section745-heading--light">
            <h2>Как «Эндемик» отвечает на то, что обычно останавливает взрослого самостоятельного покупателя</h2>
          </div>
          <div class="responses745__stack">
            {responseCards.map((card) => (
              <article class="response745-card">
                <div class="response745-card__media">
                  <img src={card.image} alt={card.alt} loading="lazy" />
                </div>
                <div class="response745-card__body">
                  <div class="response745-card__number">{card.number}</div>
                  <h3>{card.title}</h3>
                  <p class="response745-card__problem">{card.problem}</p>
                  <p>{card.answer}</p>
                  <p class="response745-card__detail">{card.detail}</p>
                  {card.cta && (
                    <a class="inline-link745" href="#contact">{card.cta}</a>
                  )}
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="split-photo745">
        <div class="split-photo745__image" style={`--split-bg: url(${images.qualifier})`}></div>
        <div class="split-photo745__content-wrap">
          <div class="container split-photo745__container">
            <div class="split-photo745__content">
              <p class="immersive745__eyebrow">ЖК «Эндемик» · Узнайте себя</p>
              <h2>Этот дом — для тех, кто больше не хочет жить в навязанном городом сценарии</h2>
              <div class="self745 self745--transparent">
                {selfSelection.map((item) => <p>{item}</p>)}
              </div>
              <blockquote class="quote745 quote745--light">
                <p>
                  «Когда дом действительно совпадает с вашим ритмом, это чувствуется сразу: меньше лишнего шума,
                  больше спокойствия, больше ощущения, что это пространство создано не для всех подряд, а именно для вашей жизни.»
                </p>
                <footer>Ощущение, которое должен давать реальный лендинг ЖК «Эндемик»</footer>
              </blockquote>
            </div>
          </div>
        </div>
      </section>

      <section class="section section--photo-band life745" style={`--section-bg: url(${images.compare})`}>
        <div class="section-band745__overlay section-band745__overlay--dark"></div>
        <div class="container life745__container">
          <div class="section745-heading section745-heading--light center745">
            <p class="immersive745__eyebrow">ЖК «Эндемик» · Формат дома</p>
            <h2>Сравните типовой бизнес-класс и тот образ жизни, который должен собирать «Эндемик»</h2>
          </div>
          <div class="responses745__stack responses745__stack--three">
            {comparisons.map((item) => (
              <article class="comparison745-card comparison745-card--overlay">
                <div class="comparison745-card__overline">{item.overline}</div>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </article>
            ))}
          </div>
          <div class="life745-table-wrap">
            <table class="life745-table">
              <thead>
                <tr>
                  <th>Фокус</th>
                  <th>На кого работает</th>
                  <th>Что человек хочет получить</th>
                  <th>Как это должно звучать в лендинге</th>
                </tr>
              </thead>
              <tbody>
                {lifeStages.map((item) => (
                  <tr>
                    <td>
                      <strong>{item.stage}</strong>
                      <span>{item.price}</span>
                    </td>
                    <td>{item.who}</td>
                    <td>{item.hire}</td>
                    <td>{item.format}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
            <div class="action745-wrap center745">
              <a href="#contact" class="button745 button745--secondary">Запросить презентацию</a>
            </div>
        </div>
      </section>

      <section class="immersive745" style={`--immersive-bg: url(${images.evolution})`}>
        <div class="container immersive745__inner immersive745__inner--right">
          <div class="immersive745__card immersive745__card--single-story">
            <article class="story745-card">
              <div class="story745-card__number">01</div>
              <h2>Дом, в котором важны спокойствие, приватность и ощущение своего места</h2>
              <p class="story745-card__problem">
                Эндемик выбирают за тишину, камерный формат и спокойную атмосферу, в которой легко жить в своём ритме.
              </p>
              <p>
                Здесь важны удобная локация, сдержанная архитектура и ощущение дома, в который приятно возвращаться каждый день.
              </p>
              <a class="inline-link745" href="#contact">Оставить заявку</a>
            </article>
          </div>
        </div>
      </section>

      <section class="section process745 section--photo-band" style={`--section-bg: url(${images.footer})`}>
        <div class="section-band745__overlay"></div>
        <div class="container process745__container">
          <div class="section745-heading section745-heading--light center745">
            <h2>Почему Эндемик подходит тем, кто ценит тишину, приватность и спокойный ритм жизни</h2>
          </div>
          <div class="process745__grid process745__grid--stacked">
            {processSteps.map((step) => (
              <article class="process745-card process745-card--stacked process745-card--light">
                <div class="process745-card__number">{step.number}</div>
                <div>
                  <h3>{step.title}</h3>
                  <p>{step.description}</p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section id="contact" class="section final745 final745--photo">
        <div class="final745__backdrop" style={`--section-bg: url(${images.footer})`}></div>
        <div class="container final745__container">
          <div class="final745__layout">
            <div class="final745__content">
              <p class="final745__eyebrow">ЖК «Эндемик» · Следующий шаг</p>
              <h2>Готовы увидеть, как может выглядеть новая версия лендинга</h2>
              <p class="final745__lead">
                Если текущее позиционирование не приводит к продажам, оставьте контакты — мы проведём встречу и расскажем вам наш подход.
              </p>
              <div class="final745__visual-card">
                <img src={images.currentPositioning} alt="Текущий экран лендинга ЖК Эндемик" loading="lazy" />
              </div>
            </div>

            <div class="final745__card">
              <form
                name={formName}
                method="POST"
                data-netlify="true"
                netlify-honeypot="bot-field"
                action="/thank-you"
                class="final745__form"
              >
                <input type="hidden" name="form-name" value={formName} />
                <input type="hidden" name="landing_slug" value={slug} />
                <input type="hidden" name="utm_source" />
                <input type="hidden" name="utm_medium" />
                <input type="hidden" name="utm_campaign" />
                <input type="hidden" name="utm_content" />
                <input type="hidden" name="utm_term" />
                <p class="hidden">
                  <label>
                    Не заполняйте это поле, если вы человек
                    <input name="bot-field" />
                  </label>
                </p>

                <div class="final745__form-copy">
                  <h3 class="final745__form-title">Назначить встречу по переупаковке</h3>
                  <p>
                    Оставьте контакты, и мы свяжемся с вами, чтобы обсудить, как может выглядеть более точная упаковка проекта.
                  </p>
                </div>

                <div class="final745__fields">
                  <div class="final745__field-block final745__form-full">
                    <label for="name" class="field-label745">Имя</label>
                    <input type="text" id="name" name="name" required class="field-input745" />
                  </div>
                  <div class="final745__field-block final745__form-full">
                    <label for="phone" class="field-label745">Телефон / Telegram</label>
                    <input type="tel" id="phone" name="phone" required class="field-input745" />
                  </div>
                  <div class="final745__field-block final745__form-full">
                    <label for="email" class="field-label745">Email</label>
                    <input type="email" id="email" name="email" required class="field-input745" />
                  </div>
                </div>
                <button type="submit" class="button745 button745--primary final745__submit">
                  Оставить контакты
