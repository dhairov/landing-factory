---
import Analytics from '../components/Analytics.astro';
import '../styles/global.css';

const slug = 'template-stay-but-grow';
const formName = 'template-stay-but-grow-repack-request';

// ─── ПЕРЕМЕННЫЕ ДЛЯ АДАПТАЦИИ ────────────────────────────────────────────────
const projectName = 'ЖК «[PROJECT_NAME]»';
const developerName = '[DEVELOPER_NAME]';
const districtContext = '[CITY_OR_DISTRICT]';
const locationProof = '[LOCATION_PROOF]';
const architectureProof = '[ARCHITECTURE_PROOF]';
const lobbyProof = '[LOBBY_PROOF]';

const proofModules = [
  'Локация, которая сохраняет связь с привычной городской картой жизни',
  'Архитектура: собранность, современность и взрослый характер объекта',
  'Лобби и общие пространства как доказательство нового класса повседневного опыта',
  'Приватность и тишина как норма, а не как привилегия',
];

const images = {
  hero: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/stay-but-grow-hero-panorama.webp',
  aha1: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/stay-but-grow-city-map.webp',
  aha2: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/stay-but-grow-architecture.webp',
  aha3: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/stay-but-grow-lobby-prestige.webp',
  qualifier: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/stay-but-grow-evening-window.webp',
  footer: 'https://d2xsxph8kpxj0f.cloudfront.net/310519663259840902/AXotyppPfFeghR67Uzfaab/stay-but-grow-urban-dusk.webp',
  currentPositioning: '/assets/template-stay-but-grow/current_positioning_user.webp',
};

// ─── БЛОК 2: ТРИГГЕРЫ ────────────────────────────────────────────────────────
const triggerPoints = [
  'Есть этап, когда работа, доход, круг общения и внутренний масштаб уже изменились — но среда повседневной жизни по-прежнему остаётся на уровне прошлого этапа.',
  'Город стал по-настоящему своим, но дом внутри него всё ещё не отражает того, кем человек уже стал.',
  'Проблема не в драме и не в бытовой катастрофе. Проблема в несоответствии.',
];

// ─── БЛОК 4: AHA-МОМЕНТЫ ─────────────────────────────────────────────────────
const responseCards = [
  {
    number: '01',
    title: 'Вырасти — не значит уехать',
    problem:
      'Часто рост воспринимается как переезд в другой город или в другой район. Но для людей с устойчивой городской биографией это не рост — это разрыв.',
    answer:
      `${projectName} можно показать как другой сценарий: не переезжать ради перемены как таковой, а перейти в более высокий класс городской жизни, сохранив всё, что уже стало своим: ${locationProof}, привычные маршруты, связи и ритм.`,
    detail:
      'Именно это превращает покупку из «смены адреса» в осмысленный переход на следующий уровень внутри своего города.',
    cta: '',
    image: images.aha1,
    alt: 'Городская карта с привычными маршрутами — рост без разрыва с городом',
  },
  {
    number: '02',
    title: 'Новый уровень считывается не по обещаниям, а по среде',
    problem:
      'Когда человек уже достиг определённого уровня, его сложно впечатлить перечнем характеристик. Он видит разницу между декларацией и реальным качеством среды.',
    answer:
      `Если у ${projectName} есть ${architectureProof}, продуманные общие пространства и ощущение взрослого адреса, это можно показать как форму городской зрелости — не просто новый ЖК, а пространство, соответствующее нынешнему уровню жизни.`,
    detail:
      'Такой проект воспринимается не как ещё одно предложение на рынке, а как точный ответ на зрелый жизненный переход.',
    cta: '',
    image: images.aha2,
    alt: 'Архитектура с собранным взрослым характером — без кричащей роскоши',
  },
  {
    number: '03',
    title: 'Высокий уровень — это не шумный статус, а спокойствие как норма',
    problem:
      'Для этого сегмента статус — не цель. Цель — среда, которая соответствует внутреннему масштабу: приватность, тишина, достойные общие пространства.',
    answer:
      `Через ${lobbyProof} и качество среды ${projectName} можно раскрыть как место, где человек не меняет декорации, а приводит образ жизни в соответствие со своим нынешним уровнем.`,
    detail:
      'Именно это и есть главный поворот: не «купить новую квартиру», а занять более взрослое место в своём городе.',
    cta: '',
    image: images.aha3,
    alt: 'Статусное лобби с приглушённым светом и взрослым характером',
  },
];

// ─── БЛОК 5: САМООТБОР ───────────────────────────────────────────────────────
const selfSelection = [
  `${projectName} имеет смысл переупаковывать именно для тех, кто не хочет начинать жизнь заново в другом месте и не ищет переезд ради перемены как таковой.`,
  'Это выбор для людей, которым важно перейти в более высокий класс городской жизни, сохранив уже сложившийся городской контур: маршруты, связи, ритм и ощущение принадлежности.',
  'Если человек хочет жить иначе, не отказываясь от собственной городской биографии, этот сегмент узнаёт себя почти сразу.',
  '«Не сбежать в лучшее место, а наконец занять более взрослое место в своём городе».',
];

// ─── БЛОК 7: ШАГИ ПРОЦЕССА ───────────────────────────────────────────────────
const processSteps = [
  {
    number: '01',
    title: 'Вы оставляете контакты и ссылку на проект',
    text: 'Показываете текущий ЖК, лендинг или рекламную коммуникацию, которая не даёт нужной конверсии.',
  },
  {
    number: '02',
    title: 'Мы собираем гипотезу переупаковки',
    text: 'Смотрим, как проект позиционируется сейчас, и находим, где его сильные стороны остаются слишком общими для сценария «остаться, но вырасти».',
  },
  {
    number: '03',
    title: 'Проводим встречу по проекту',
    text: 'Показываем, как можно пересобрать оффер, структуру страницы и аргументацию под сценарий зрелого городского перехода без разрыва с привычным.',
  },
  {
    number: '04',
    title: 'Фиксируем следующий шаг',
    text: 'После этого определяем, что делать дальше: корректировать сегмент, перепрошивать оффер или полностью пересобирать упаковку проекта.',
  },
];
---

<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{projectName} — жить на новом уровне, не уезжая из своего города</title>
    <meta
      name="description"
      content={`Показываем, как ${projectName} можно раскрыть как переход в более высокий класс городской жизни — без разрыва с привычным городом, маршрутами и связями.`}
    />
  </head>
  <body class="landing-745">
    <Analytics landingSlug={slug} />

    <main>
      <!-- БЛОК 1: HERO -->
      <section class="hero745 section section--photo-hero">
        <div class="hero745__backdrop" style={`--section-bg: url(${images.hero})`}></div>
        <div class="container hero745__container">
          <div class="hero745__label">{districtContext} · новый уровень жизни без переезда из своего города</div>
          <div class="hero745__grid">
            <div class="hero745__content hero745__content--glass">
              <h1>Жить на новом уровне — не уезжая из своего города</h1>
              <p class="hero745__lead">
                Когда жизнь уже выросла, особенно важно, чтобы ей соответствовали дом, адрес, ритм и среда вокруг. Иногда для этого не нужно начинать всё заново в другом месте. Достаточно выбрать пространство, в котором ваш сегодняшний уровень наконец становится видимым.
              </p>
              <p class="hero745__offer-line">Архитектура, приватность, локация и качество общих пространств могут сделать городской рост естественным продолжением жизни</p>
              <div class="hero745__actions hero745__actions--stacked">
                <a class="button745 button745--primary" href="#contact">запросить консультацию</a>
              </div>
            </div>

            <aside class="hero745__card hero745__card--floating">
              <div class="hero745__card-body">
                <h2>{projectName} — пространство для тех, кто хочет перейти в более высокий класс городской жизни, не разрушая уже сложившийся городской контур</h2>
                <p class="hero745__meta">Не сбежать в «лучшее место», а наконец занять более взрослое место в своём городе</p>
                <p>
                  Этот проект можно показывать не как переезд ради перемены, а как осмысленный переход на следующий уровень.
                </p>
              </div>
            </aside>
          </div>
        </div>
      </section>

      <!-- БЛОК 2: ТРИГГЕРЫ -->
      <section class="section section--tight triggers745-wrap triggers745-wrap--hero-continued">
        <div class="hero745__backdrop hero745__backdrop--continued" style={`--section-bg: url(${images.hero})`}></div>
        <div class="triggers745__tone"></div>
        <div class="container triggers745__container">
          <div class="triggers745">
            {triggerPoints.map((item) => <p>{item}</p>)}
          </div>
        </div>
      </section>

      <!-- БЛОК 3: ГОТОВОЕ РЕШЕНИЕ (REFRAMING) -->
      <section class="immersive745 immersive745--hero" style={`--immersive-bg: url(${images.aha1})`}>
        <div class="container immersive745__inner">
          <div class="immersive745__card">
              <p class="immersive745__eyebrow">{projectName} · сценарий «остаться, но вырасти»</p>
              <h2>Чтобы вырасти, не обязательно начинать жизнь заново</h2>
              <p class="immersive745__body immersive745__body--light">
                Есть другой сценарий. Не переезжать ради перемены как таковой, а перейти в более высокий класс городской жизни, сохранив всё, что уже стало своим: город, привычные маршруты, любимые места, связи, ритм и ощущение принадлежности.
              </p>
              <p class="immersive745__body immersive745__body--light">
                Если посмотреть на {projectName} не через общий рынок, а через задачу человека, который хочет вырасти внутри своего города, в нём можно увидеть не просто квадратные метры, а более зрелую организацию повседневной жизни.
              </p>
              <p class="immersive745__body immersive745__body--light">
                В этом случае новый дом становится не разрывом, а продолжением роста.
              </p>
              <div class="immersive745__facts">
                {proofModules.map((proof) => <span>{proof}</span>)}
              </div>
              <p class="immersive745__bridge immersive745__bridge--light">Правильно поданный жилой проект даёт именно это: возможность жить иначе, не отказываясь от собственной городской биографии.</p>
          </div>
        </div>
      </section>

      <!-- БЛОК 4: AHA-МОМЕНТЫ -->
      <section class="section responses745 section--photo-soft" style={`--section-bg: url(${images.aha2})`}>
        <div class="responses745__veil"></div>
        <div class="container responses745__container">
          <div class="section745-heading center745 section745-heading--light">
            <h2>Три причины, почему этот сценарий может стать причиной выбора</h2>
          </div>
          <div class="responses745__stack">
            {responseCards.map((card) => (
              <article class="response745-card">
                <div class="response745-card__media">
                  <img src={card.image} alt={card.alt} loading="lazy" />
                </div>
                <div class="response745-card__body">
                  <div class="response745-card__number">{card.number}</div>
                  <h3>{card.title}</h3>
                  <p class="response745-card__problem">{card.problem}</p>
                  <p>{card.answer}</p>
                  <p class="response745-card__detail">{card.detail}</p>
                  {card.cta && (
                    <a class="inline-link745" href="#contact">{card.cta}</a>
                  )}
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <!-- БЛОК 5: САМООТБОР -->
      <section class="split-photo745">
        <div class="split-photo745__image" style={`--split-bg: url(${images.qualifier})`}></div>
        <div class="split-photo745__content-wrap">
          <div class="container split-photo745__container">
            <div class="split-photo745__content">
              <p class="immersive745__eyebrow">{projectName} · самоотбор сегмента</p>
              <h2>Когда уровень жизни вырос, компромисс ощущается всё сильнее</h2>
              <div class="self745 self745--transparent self745--light">
                {selfSelection.map((item) => <p>{item}</p>)}
              </div>
              <blockquote class="quote745 quote745--light">
                <p>
                  «Не сбежать в лучшее место, а наконец занять более взрослое место в своём городе».
                </p>
                <footer>Сегмент «остаться, но вырасти»</footer>
              </blockquote>
            </div>
          </div>
        </div>
      </section>

      <!-- БЛОК 6: B2B РАЦИОНАЛЬНОСТЬ -->
      <section class="immersive745 immersive745--contrast" style={`--immersive-bg: url(${images.aha3})`}>
        <div class="container immersive745__inner immersive745__inner--right">
          <div class="immersive745__card immersive745__card--single-story">
            <div class="story745-card story745-card--light-copy">
              <div class="story745-card__number">06</div>
              <h2>Сценарий «остаться, но вырасти» — это отдельная мотивационная логика, а не общий апгрейд жилья.</h2>
              <p class="story745-card__problem">В этом сегменте люди покупают не только планировку, фасад или лобби. Они покупают переход в более высокий класс жизни, не разрушая уже сложившийся городской контур. Когда проект упакован через этот сценарий, он воспринимается не как ещё одно предложение на рынке, а как точный ответ на зрелый жизненный переход.</p>
              <a class="inline-link745 inline-link745--light" href="#contact">Посмотреть, как этот сценарий упаковать для вашего проекта</a>
            </div>
          </div>
        </div>
      </section>

      <!-- БЛОК 7: ПРОЦЕСС РАБОТЫ -->
      <section class="section process745 section--photo-band" style={`--section-bg: url(${images.footer})`}>
        <div class="section-band745__overlay section-band745__overlay--dark"></div>
        <div class="container process745__container">
          <div class="section745-heading center745 section745-heading--light section745-heading--max">
            <h2>Проект начинает считываться как следующий шаг в городской жизни клиента</h2>
            <p>Вместо того чтобы описывать {projectName} через общий набор атрибутов, можно переупаковать его вокруг более точной задачи: помочь человеку перейти в более высокий класс городской жизни, не разрушая уже сложившийся городской контур.</p>
          </div>
          <div class="process745__grid process745__grid--stacked">
            {processSteps.map((step) => (
              <article class="process745-card process745-card--light process745-card--stacked">
                <div class="process745-card__number">{step.number}</div>
                <h3>{step.title}</h3>
                <p>{step.text}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <!-- БЛОК 8: СКРИНШОТ + ФОРМА -->
      <section id="contact" class="section final745 final745--photo">
        <div class="final745__backdrop" style={`--final-bg: url(${images.footer})`}></div>
        <div class="container final745__container">
          <div class="final745__layout">
            <div class="final745__media-copy">
              <p class="final745__eyebrow">Текущий пример позиционирования проекта</p>
              <h2>Если текущее позиционирование не приводит к продажам — покажем, как может выглядеть переупаковка {projectName} под сценарий «остаться, но вырасти»</h2>

              <div class="final745__positioning-shot">
                <img src={images.currentPositioning} alt={`Текущее позиционирование ${projectName}`} loading="lazy" />
              </div>
            </div>
            <div class="final745__card">
              <p class="final745__eyebrow final745__eyebrow--dark">Стратегическая встреча по переупаковке</p>
              <form
                name={formName}
                method="POST"
                data-netlify="true"
                netlify-honeypot="bot-field"
                action="/thank-you"
                class="final745__form"
              >
                <input type="hidden" name="form-name" value={formName} />
                <input type="hidden" name="landing_slug" value={slug} />
                <input type="hidden" name="utm_source" value="" />
                <input type="hidden" name="utm_medium" value="" />
                <input type="hidden" name="utm_campaign" value="" />
                <input type="hidden" name="utm_content" value="" />
                <input type="hidden" name="utm_term" value="" />

                <p class="sr-only">
                  <label>
                    Не заполняйте это поле, если вы человек:
                    <input name="bot-field" />
                  </label>
                </p>

                <div class="final745__form-grid">
                  <div class="final745__field-block">
                    <label for="name" class="field-label745">Имя</label>
                    <input type="text" id="name" name="name" required class="field-input745" />
                  </div>

                  <div class="final745__field-block final745__form-full">
                    <label for="phone" class="field-label745">Телефон / Telegram</label>
                    <input type="tel" id="phone" name="phone" required class="field-input745" />
                  </div>

                  <div class="final745__field-block final745__form-full">
                    <label for="email" class="field-label745">Email</label>
                    <input type="email" id="email" name="email" required class="field-input745" />
                  </div>
                </div>

                <button type="submit" class="button745 button745--primary final745__submit">
                  записаться на встречу
                </button>
              </form>
            </div>
          </div>
        </div>
      </section>
    </main>

    <script define:vars={{ slug }}>
      import { populateUTMFields, trackFormSubmission } from '../utils/analytics.ts';

      const form = document.querySelector('#contact form');

      if (form instanceof HTMLFormElement) {
        populateUTMFields(form);
        form.addEventListener('submit', () => {
          populateUTMFields(form);
          trackFormSubmission(slug);
        });
      }
    </script>
  </body>
</html>

<style>
  :global(body.landing-745) {
    background: #130f0d;
    color: #241b16;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif;
  }
  .landing-745 main {
    overflow-x: hidden;
    background: #f6efe8;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif;
    color: #fff8f2;
  }
  .landing-745 h1,.landing-745 h2,.landing-745 h3,.landing-745 h4,.landing-745 h5,.landing-745 h6,
  .landing-745 p,.landing-745 a,.landing-745 span,.landing-745 label,.landing-745 input,
  .landing-745 textarea,.landing-745 button,.landing-745 th,.landing-745 td,
  .landing-745 blockquote,.landing-745 li {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif;
  }
  .section { position: relative; }
  .hero745, .final745, .responses745, .process745 { position: relative; }
  .hero745__container, .responses745__container, .process745__container, .final745__container {
    position: relative; z-index: 2;
  }
  .section--photo-hero,.section--photo-band,.section--photo-soft,.final745--photo {
    background-image: var(--section-bg);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }
  .hero745 {
    min-height: clamp(760px, 92vh, 980px);
    display: flex;
    align-items: stretch;
    padding: 36px 0 28px;
    overflow: hidden;
  }
  .hero745__backdrop {
    position: absolute; inset: 0;
    background-image: linear-gradient(120deg, rgba(17, 12, 9, 0.82), rgba(17, 12, 9, 0.38)), var(--section-bg);
    transform: scale(1.04); transform-origin: center;
    background-size: cover; background-position: center;
  }
  .hero745__backdrop--continued {
    background-image: linear-gradient(180deg, rgba(17, 12, 9, 0.3), rgba(17, 12, 9, 0.72)), var(--section-bg);
