---
// Beeline B2B GAP Dashboard v3 — Final
---
<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>beeline B2B · GAP Dashboard (Grinbox)</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{
      --y:#FFD600;--yl:#FFFDE7;--ylm:#FFF9C4;
      --k:#0A0A0A;--g7:#333;--g5:#666;--g3:#CCC;--g2:#E5E7EB;--g1:#F5F5F5;--g05:#FAFAFA;--w:#FFF;
      --green:#059669;--greenl:#dcfce7;--greend:#166534;
      --red:#dc2626;--redl:#fee2e2;
      --orange:#d97706;--orangel:#fef3c7;
      --blue:#2563eb;
      --r:12px;--rs:8px;
      --sh:0 1px 3px rgba(0,0,0,.07),0 1px 2px rgba(0,0,0,.04)
    }
    body{font-family:'Inter',-apple-system,sans-serif;background:#f8f9fa;color:var(--k);-webkit-font-smoothing:antialiased}

    /* HEADER */
    .hd{background:var(--w);border-bottom:1px solid var(--g2);padding:0 32px;height:56px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100}
    .hd-l{display:flex;align-items:center;gap:12px}
    .logo{background:var(--y);color:var(--k);font-weight:800;font-size:13px;padding:4px 10px;border-radius:6px}
    .hd-t{font-size:14px;font-weight:500;color:var(--g5)}
    .hd-r{display:flex;align-items:center;gap:14px}
    .sdot{width:8px;height:8px;border-radius:50%;background:var(--green);display:inline-block}
    .stxt{font-size:12px;color:var(--g5)}
    .btn-r{background:var(--g1);border:1px solid var(--g2);border-radius:var(--rs);padding:6px 14px;font-size:13px;font-weight:500;color:var(--g7);cursor:pointer;font-family:inherit}
    .btn-r:hover{background:var(--g2)}

    /* LAYOUT */
    .main{max-width:1360px;margin:0 auto;padding:28px 28px 80px}

    /* KPI ROW */
    .kpi-row{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:20px}
    .kpi{border:1px solid var(--g2);border-radius:var(--r);padding:20px 22px;background:var(--w);box-shadow:var(--sh)}
    .kpi.hl{border-color:var(--y);background:var(--yl);border-left:4px solid var(--y)}
    .kpi-lbl{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;color:var(--g5);margin-bottom:8px}
    .kpi-val{font-size:30px;font-weight:900;letter-spacing:-1.5px;line-height:1;color:var(--k)}
    .kpi-sub{font-size:12px;color:var(--g5);margin-top:6px}
    .kpi-note{font-size:11px;color:var(--g5);margin-top:4px}
    .calc-btn{background:none;border:none;color:var(--blue);font-size:11px;cursor:pointer;font-family:inherit;text-decoration:underline;text-decoration-style:dotted;padding:0}
    .calc-btn:hover{color:#1d4ed8}

    /* CALC PANEL */
    .calc-panel{display:none;background:#f0f7ff;border:1px solid #bfdbfe;border-radius:var(--r);padding:20px;margin-bottom:20px}
    .calc-panel.open{display:block}
    .calc-ttl{font-size:13px;font-weight:700;color:#1e40af;margin-bottom:10px}
    .calc-desc{font-size:12px;color:#374151;line-height:1.6;margin-bottom:14px}
    .calc-tbl{width:100%;border-collapse:collapse;font-size:12px}
    .calc-tbl th{text-align:left;color:var(--g5);font-weight:600;padding:5px 10px;border-bottom:1px solid #bfdbfe;background:#e0f2fe}
    .calc-tbl td{padding:6px 10px;color:#374151;border-bottom:1px solid #dbeafe}
    .calc-tbl tr:last-child td{border-bottom:none;font-weight:700;color:#1e40af;background:#eff6ff}
    .calc-note{font-size:11px;color:var(--g5);margin-top:10px;font-style:italic}

    /* TWO-COL */
    .two-col{display:grid;grid-template-columns:1fr 1.7fr;gap:16px;margin-bottom:20px}
    .card{background:var(--w);border:1px solid var(--g2);border-radius:var(--r);padding:22px 24px;box-shadow:var(--sh)}
    .card-ttl{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.7px;color:var(--g5);margin-bottom:4px}
    .card-sub{font-size:12px;color:var(--g5);margin-bottom:16px}

    /* PROGRESS */
    .prog-wrap{margin-bottom:18px}
    .prog-bg{background:var(--g1);border-radius:100px;height:28px;overflow:hidden}
    .prog-fill{background:var(--y);height:100%;border-radius:100px;display:flex;align-items:center;padding-left:12px;transition:width 1s ease}
    .prog-pct{font-size:13px;font-weight:800;color:var(--k)}

    /* STACKED BAR */
    .stacked-lbl{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.7px;color:var(--g5);margin-bottom:10px;margin-top:18px}
    .stacked-bar{display:flex;height:48px;border-radius:10px;overflow:hidden;border:1px solid var(--g2)}
    .seg{display:flex;align-items:center;justify-content:center;font-weight:700;font-size:13px;transition:width 1s ease}
    .seg-g3{background:var(--y);color:var(--k)}
    .seg-g2{background:#9ca3af;color:#fff;font-size:11px}
    .seg-g1{background:var(--g1);color:var(--g5);font-size:11px}
    .stacked-legend{display:flex;gap:20px;margin-top:10px;flex-wrap:wrap}
    .leg-item{display:flex;align-items:center;gap:7px;font-size:12px;color:var(--g7)}
    .leg-dot{width:10px;height:10px;border-radius:3px;flex-shrink:0}

    /* LEADERBOARD */
    .lb-tbl{width:100%;border-collapse:collapse}
    .lb-tbl th{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:var(--g5);padding:8px 14px;text-align:left;border-bottom:1px solid var(--g2);background:var(--g05)}
    .lb-tbl td{padding:13px 14px;border-bottom:1px solid var(--g1);vertical-align:middle}
    .lb-tbl tr:last-child td{border-bottom:none}
    .lb-tbl tr.gold-row{background:var(--yl)}
    .medal{font-size:20px;line-height:1}
    .lb-name{font-weight:700;font-size:14px;color:var(--k)}
    .lb-ins{font-size:11px;margin-top:2px}
    .lb-ins.found{color:var(--green);font-weight:500}
    .lb-ins.none{color:var(--g5);font-style:italic}
    .frac{font-size:14px;font-weight:700}
    .frac.g{color:var(--green)}
    .frac.o{color:var(--orange)}
    .frac.r{color:var(--red)}
    .score-big{font-size:26px;font-weight:900;color:var(--k);text-align:right;letter-spacing:-1px}

    /* SECTION LABEL */
    .sec-lbl{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.9px;color:var(--g5);margin-bottom:14px;margin-top:4px}

    /* TEAM CARDS */
    .team-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:20px}
    .tc{background:var(--w);border:1px solid var(--g2);border-radius:var(--r);overflow:hidden;box-shadow:var(--sh)}
    .tc-hd{padding:16px 20px 14px}
    .tc-hd.gold{border-top:3px solid var(--y);background:var(--yl)}
    .tc-hd.silver{border-top:3px solid #9ca3af;background:#f9fafb}
    .tc-hd.grey{border-top:3px solid var(--g2);background:var(--g05)}
    .rank-pill{display:inline-block;font-size:10px;font-weight:700;padding:2px 8px;border-radius:20px;margin-bottom:5px}
    .rank-pill.gold{background:var(--y);color:var(--k)}
    .rank-pill.silver{background:var(--g2);color:var(--g7)}
    .rank-pill.grey{background:var(--g1);color:var(--g5)}
    .tc-name{font-size:17px;font-weight:800;color:var(--k);letter-spacing:-.3px}
    .tc-bd{padding:16px 20px}

    /* METRICS ROW */
    .mrow{display:flex;border:1px solid var(--g2);border-radius:var(--rs);overflow:hidden;margin-bottom:14px}
    .mcell{flex:1;padding:10px 12px;text-align:center;border-right:1px solid var(--g2)}
    .mcell:last-child{border-right:none}
    .mcell-lbl{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:var(--g5);margin-bottom:4px}
    .mcell-val{font-size:17px;font-weight:800}
    .mcell-val.g{color:var(--green)}
    .mcell-val.o{color:var(--orange)}
    .mcell-val.r{color:var(--red)}
    .mcell-val.grey{color:var(--g5)}

    /* MINI PROGRESS */
    .mp{margin-bottom:10px}
    .mp-row{display:flex;justify-content:space-between;margin-bottom:4px}
    .mp-lbl{font-size:11px;color:var(--g5);font-weight:500}
    .mp-pct{font-size:11px;font-weight:700;color:var(--g7)}
    .mp-bg{background:var(--g1);border-radius:100px;height:6px}
    .mp-fill{height:100%;border-radius:100px}
    .mp-fill.y{background:var(--y)}
    .mp-fill.o{background:var(--orange)}
    .mp-fill.r{background:var(--red)}

    /* INSIGHTS */
    .ins-block{margin-bottom:14px}
    .ins-item{border:1px solid var(--g2);border-left:3px solid var(--y);border-radius:var(--rs);background:var(--yl);margin-bottom:8px;overflow:hidden}
    .ins-item.empty{border-left-color:var(--g2);background:var(--g05)}
    .ins-hd{display:flex;align-items:center;justify-content:space-between;padding:10px 14px;cursor:pointer;user-select:none}
    .ins-hd-l{display:flex;align-items:center;gap:8px;min-width:0}
    .ins-tag{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.7px;padding:2px 7px;border-radius:4px;flex-shrink:0}
    .ins-tag.found{background:var(--greenl);color:var(--greend)}
    .ins-tag.none{background:var(--g1);color:var(--g5)}
    .ins-title{font-size:13px;font-weight:600;color:var(--k);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .ins-title.grey{color:var(--g5);font-style:italic;font-weight:400}
    .ins-chev{font-size:11px;color:var(--g5);flex-shrink:0;transition:transform .2s;margin-left:8px}
    .ins-chev.open{transform:rotate(180deg)}
    .ins-body{display:none;padding:0 14px 14px;border-top:1px solid rgba(0,0,0,.06)}
    .ins-body.open{display:block}
    .ins-field{margin-top:10px}
    .ins-field-lbl{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.7px;color:var(--g5);margin-bottom:3px}
    .ins-field-val{font-size:13px;color:#374151;line-height:1.55}
    .ins-field-val.bold{font-weight:600;color:var(--k)}
    .ins-meta{display:flex;gap:12px;margin-top:10px;padding-top:10px;border-top:1px solid rgba(0,0,0,.06)}
    .ins-meta-item{flex:1}
    .ins-meta-lbl{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:var(--g5);margin-bottom:3px}
    .ins-meta-val{font-size:13px;font-weight:700;color:var(--k)}

    /* CHECKLIST */
    .cl-ttl{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:var(--g5);margin-bottom:8px}
    .cl-item{display:flex;align-items:flex-start;gap:7px;margin-bottom:5px;font-size:12px;color:var(--g7);line-height:1.45}
    .cl-ico{width:15px;height:15px;border-radius:3px;display:flex;align-items:center;justify-content:center;font-size:9px;flex-shrink:0;margin-top:1px}
    .cl-ico.done{background:var(--greenl);color:var(--greend)}
    .cl-ico.fail{background:var(--redl);color:var(--red)}

    /* SCORE BADGE */
    .score-badge{text-align:center;padding:12px;border-radius:var(--rs);margin-top:14px}
    .score-badge.gold{background:var(--y)}
    .score-badge.silver{background:var(--g2)}
    .score-badge.grey{background:var(--g1)}
    .score-num{font-size:22px;font-weight:900;color:var(--k)}
    .score-sub{font-size:11px;color:var(--g7);font-weight:500}

    /* FOOTER */
    .ft{border-top:1px solid var(--g2);padding:16px 28px;display:flex;justify-content:space-between;align-items:center;background:var(--w);margin-top:8px}
    .ft-l{font-size:12px;color:var(--g5)}
    .ft-a{font-size:12px;color:var(--blue);text-decoration:none}
    .ft-a:hover{text-decoration:underline}

    @media(max-width:1100px){.two-col{grid-template-columns:1fr}.team-grid{grid-template-columns:1fr 1fr}}
    @media(max-width:700px){.kpi-row{grid-template-columns:1fr 1fr}.team-grid{grid-template-columns:1fr}.main{padding:16px 16px 60px}}
  </style>
</head>
<body>

<header class="hd">
  <div class="hd-l">
    <span class="logo">beeline</span>
    <span class="hd-t">B2B &middot; GAP Dashboard (Grinbox)</span>
  </div>
  <div class="hd-r">
    <span class="sdot"></span>
    <span class="stxt" id="stxt">Загрузка&hellip;</span>
    <button class="btn-r" onclick="loadData()">&#8635; Обновить</button>
  </div>
</header>

<div class="main">

  <!-- KPI ROW -->
  <div class="kpi-row">
    <div class="kpi hl">
      <div class="kpi-lbl">GAP (Grinbox)</div>
      <div class="kpi-val">2,7 млрд ₽</div>
      <div class="kpi-sub">B2B-направление &middot; цель программы</div>
    </div>
    <div class="kpi">
      <div class="kpi-lbl">Прибыль от найденных инсайтов</div>
      <div class="kpi-val" id="kPot">—</div>
      <div class="kpi-sub" id="kPotSub">до конца 2026 года</div>
      <div class="kpi-note"><button class="calc-btn" onclick="toggleCalc()">Как считается? ↓</button></div>
    </div>
    <div class="kpi">
      <div class="kpi-lbl">Супер-инсайтов найдено</div>
      <div class="kpi-val" id="kIns">—</div>
      <div class="kpi-sub" id="kInsSub">из 3 команд</div>
    </div>
    <div class="kpi">
      <div class="kpi-lbl">Спринт</div>
      <div class="kpi-val">1 / 6</div>
      <div class="kpi-sub">недель программы</div>
    </div>
  </div>

  <!-- CALC PANEL -->
  <div class="calc-panel" id="calcPanel">
    <div class="calc-ttl">📊 Методология расчёта «Прибыль от найденных инсайтов»</div>
    <div class="calc-desc">
      Это <strong>не текущая выручка</strong> — это реалистичная прибыль, которую может принести каждый найденный инсайт
      до конца 2026 года при условии запуска продаж. Расчёт учитывает три дисконта:
      (1) время на разработку и переупаковку продукта,
      (2) время на развёртывание отдела продаж и пилотные продажи,
      (3) пилотный охват рынка — не весь SOM, а 20% от него в первый год.
    </div>
    <table class="calc-tbl">
      <thead>
        <tr><th>Параметр</th><th>Группа 3: ОАТС</th><th>Группа 2: Микробизнес</th></tr>
      </thead>
      <tbody>
        <tr><td>Средний чек (мес.)</td><td>18 000 ₽</td><td>1 000 ₽</td></tr>
        <tr><td>Маржинальность</td><td>~95%</td><td>~70%</td></tr>
        <tr><td>Целевой рынок (SAM)</td><td>47 950 объектов КИИ</td><td>241 200 МСБ с предзаписью</td></tr>
        <tr><td>SOM (реалистичный захват)</td><td>10% = 4 795 клиентов</td><td>5% = 12 060 клиентов</td></tr>
        <tr><td>Годовой потенциал прибыли (полный)</td><td>984 млн ₽</td><td>101 млн ₽</td></tr>
        <tr><td>Дисконт 1: месяцев продаж до конца года</td><td>5 из 12 (старт авг. 2026)</td><td>5 из 12</td></tr>
        <tr><td>Дисконт 2: пилотный охват SOM</td><td>20%</td><td>20%</td></tr>
        <tr><td><strong>Реалистичная прибыль до конца 2026</strong></td><td><strong>~82 млн ₽</strong></td><td><strong>~8 млн ₽</strong></td></tr>
      </tbody>
    </table>
    <div class="calc-note">* Группа 1 не учтена — супер-инсайт ещё не найден. По мере появления новых инсайтов цифра будет расти. Полный потенциал при захвате SOM за год: 1 085 млн ₽.</div>
  </div>

  <!-- TWO-COL -->
  <div class="two-col">

    <!-- LEFT: PROGRESS + STACKED -->
    <div class="card">
      <div class="card-ttl">Прогресс закрытия GAP</div>
      <div class="card-sub" id="progSub">— млн ₽ из 2 700 млн ₽</div>
      <div class="prog-wrap">
        <div class="prog-bg">
          <div class="prog-fill" id="progFill" style="width:0%">
            <span class="prog-pct" id="progPct">0%</span>
          </div>
        </div>
      </div>
      <div class="stacked-lbl">Вклад команд в потенциал прибыли</div>
      <div class="stacked-bar">
        <div class="seg seg-g3" id="segG3" style="width:90.7%">90.7%</div>
        <div class="seg seg-g2" id="segG2" style="width:9.3%">9.3%</div>
        <div class="seg seg-g1" id="segG1" style="width:0.1%"></div>
      </div>
      <div class="stacked-legend">
        <div class="leg-item"><div class="leg-dot" style="background:var(--y)"></div><span id="legG3">Группа 3: ОАТС — 984 млн ₽</span></div>
        <div class="leg-item"><div class="leg-dot" style="background:#9ca3af"></div><span id="legG2">Группа 2: Микробизнес — 101 млн ₽</span></div>
        <div class="leg-item"><div class="leg-dot" style="background:var(--g1);border:1px solid var(--g2)"></div><span id="legG1">Группа 1: Платформа — инсайт не найден</span></div>
      </div>
    </div>

    <!-- RIGHT: LEADERBOARD -->
    <div class="card">
      <div class="card-ttl">Рейтинг команд &middot; Спринт 1</div>
      <div class="card-sub">Задачи спринта 40% + методология DTBD 20% + супер-инсайт 40%</div>
      <table class="lb-tbl">
        <thead>
          <tr>
            <th style="width:36px">#</th>
            <th>Команда</th>
            <th>Задачи</th>
            <th>DTBD</th>
            <th>Потенциал</th>
            <th style="text-align:right">Балл</th>
          </tr>
        </thead>
        <tbody id="lbBody">
          <tr><td colspan="6" style="text-align:center;color:var(--g5);padding:20px">Загрузка...</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- TEAM CARDS -->
  <div class="sec-lbl">Детали по командам</div>
  <div class="team-grid" id="teamGrid"></div>

</div>

<!-- FOOTER -->
<div class="ft">
  <div class="ft-l" id="ftTxt">Данные из Google Sheets &middot; Потенциал = прибыль при захвате SOM, не текущая выручка</div>
  <a class="ft-a" href="https://docs.google.com/spreadsheets/d/18VrhTHQPdVgxVZZF3is3Ozce56rpY-j-wmikH8Dpy08/edit" target="_blank">Редактировать данные →</a>
</div>

<script>
// ── STATIC DATA (Sprint 1) ────────────────────────────────────────────────────
const TEAMS = [
  {
    id:'g3', name:'Группа 3: ОАТС', rankClass:'gold',
    tasks_done:6, tasks_total:6, dtbd_score:6,
    has_insight:true,
    pot_full:984, pot_year:82,
    score:92,
    insights:[{
      title:'Резервный канал связи: соответствие нормативам КИИ',
      dream:'Быть уверенным, что объект не остановится и не получит штраф при блокировке сотовой связи — иметь резервный канал, который просто работает, когда основной падает.',
      core_job:'Соответствовать нормативным требованиям по безопасности и резервированию каналов связи при блокировках сотовой связи. Регулятор требует наличия резервного канала — его отсутствие грозит штрафами и остановкой работы объекта.',
      micro_job:'Подключить резервный канал связи с минимальными усилиями и без перестройки существующей инфраструктуры.',
      segment:'Объекты критической инфраструктуры (КИИ): тепловые электростанции, больницы, водоканалы, объекты ЖКХ, промышленные предприятия с регуляторными требованиями по резервированию каналов связи.',
      product:'Облачная АТС билайн как резервный канал связи — подключается поверх существующей инфраструктуры, не требует замены оборудования.',
      check:'18 000 ₽/мес',
      margin:'~95% (услуга почти не используется — чистый резерв)',
      sprint:1
    }],
    tasks:[
