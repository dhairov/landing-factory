// ── RENDER ────────────────────────────────────────────────────────────────────
function render(teams) {
  const sorted = [...teams].sort((a,b) => b.score - a.score);
  const totalYear = teams.reduce((s,t) => s+t.pot_year, 0);
  const totalFull = teams.reduce((s,t) => s+t.pot_full, 0);
  const insCount = teams.filter(t => t.has_insight).length;
  const gapPct = (totalYear/2700*100).toFixed(1);

  // KPI
  document.getElementById('kPot').textContent = totalYear > 0 ? '~'+totalYear+' млн ₽' : '—';
  document.getElementById('kPotSub').textContent = gapPct+'% от цели GAP · до конца 2026';
  document.getElementById('kIns').textContent = insCount;
  document.getElementById('kInsSub').textContent = 'из '+teams.length+' команд';

  // Progress
  const pPct = Math.min(totalYear/2700*100, 100).toFixed(1);
  document.getElementById('progSub').textContent = totalYear+' млн ₽ из 2 700 млн ₽ (реалистичный сценарий до конца года)';
  document.getElementById('progFill').style.width = pPct+'%';
  document.getElementById('progPct').textContent = pPct+'%';

  // Stacked
  if(totalFull > 0) {
    const g3 = teams.find(t=>t.id==='g3'), g2 = teams.find(t=>t.id==='g2'), g1 = teams.find(t=>t.id==='g1');
    const p3 = (g3.pot_full/totalFull*100).toFixed(1);
    const p2 = (g2.pot_full/totalFull*100).toFixed(1);
    document.getElementById('segG3').style.width = p3+'%';
    document.getElementById('segG3').textContent = p3+'%';
    document.getElementById('segG2').style.width = p2+'%';
    document.getElementById('segG2').textContent = p2+'%';
    document.getElementById('segG1').style.width = '0.1%';
    document.getElementById('legG3').textContent = g3.name+' — '+g3.pot_full+' млн ₽';
    document.getElementById('legG2').textContent = g2.name+' — '+g2.pot_full+' млн ₽';
    document.getElementById('legG1').textContent = g1.name+' — инсайт не найден';
  }

  // Leaderboard
  const medals = ['🥇','🥈','🥉'];
  document.getElementById('lbBody').innerHTML = sorted.map((t,i) => {
    const fc = t.tasks_done===t.tasks_total?'g':t.tasks_done>=t.tasks_total/2?'o':'r';
    const ins = t.has_insight
      ? '<div class="lb-ins found">⚡ '+t.insights[0].title+'</div>'
      : '<div class="lb-ins none">Инсайт не найден</div>';
    const pot = t.pot_full>0 ? t.pot_full+' млн ₽' : '—';
    return '<tr class="'+(i===0?'gold-row':'')+'"><td><span class="medal">'+medals[i]+'</span></td><td><div class="lb-name">'+t.name+'</div>'+ins+'</td><td><span class="frac '+fc+'">'+t.tasks_done+'/'+t.tasks_total+'</span></td><td><span class="frac">'+t.dtbd_score+'/10</span></td><td style="font-size:13px;font-weight:600">'+pot+'</td><td><div class="score-big">'+t.score+'</div></td></tr>';
  }).join('');

  // Team cards
  document.getElementById('teamGrid').innerHTML = sorted.map((t,i) => {
    const tPct = Math.round(t.tasks_done/t.tasks_total*100);
    const dPct = Math.round(t.dtbd_score/10*100);
    const tBar = tPct===100?'y':tPct>=50?'o':'r';
    const dBar = dPct>=60?'y':dPct>=30?'o':'r';
    const tCls = t.tasks_done===t.tasks_total?'g':t.tasks_done>=t.tasks_total/2?'o':'r';
    const dCls = t.dtbd_score>=6?'g':t.dtbd_score>=4?'o':'r';
    const pCls = t.pot_full>0?'g':'grey';
    const pVal = t.pot_full>0?t.pot_full+' млн ₽':'—';
    const rankLabels = ['1 Место','2 Место','3 Место'];
    const scoreCls = i===0?'gold':i===1?'silver':'grey';

    // Insights
    let insHtml = '';
    if(t.insights.length > 0) {
      insHtml = t.insights.map((ins,idx) => `
        <div class="ins-item">
          <div class="ins-hd" onclick="toggleIns('${t.id}-${idx}')">
            <div class="ins-hd-l">
              <span class="ins-tag found">⚡ Супер-инсайт</span>
              <span class="ins-title">${ins.title}</span>
            </div>
            <span class="ins-chev" id="chev-${t.id}-${idx}">▼</span>
          </div>
          <div class="ins-body" id="ibody-${t.id}-${idx}">
            <div class="ins-field">
              <div class="ins-field-lbl">Dream — мечта клиента</div>
              <div class="ins-field-val">${ins.dream}</div>
            </div>
            <div class="ins-field">
              <div class="ins-field-lbl">Core Job — главная задача</div>
              <div class="ins-field-val bold">${ins.core_job}</div>
            </div>
            <div class="ins-field">
              <div class="ins-field-lbl">Micro Job — подзадача</div>
              <div class="ins-field-val">${ins.micro_job}</div>
            </div>
            <div class="ins-field">
              <div class="ins-field-lbl">Сегмент</div>
              <div class="ins-field-val">${ins.segment}</div>
            </div>
            <div class="ins-field">
              <div class="ins-field-lbl">Продукт билайн</div>
              <div class="ins-field-val bold">${ins.product}</div>
            </div>
            <div class="ins-meta">
              <div class="ins-meta-item"><div class="ins-meta-lbl">Средний чек</div><div class="ins-meta-val">${ins.check}</div></div>
              <div class="ins-meta-item"><div class="ins-meta-lbl">Маржинальность</div><div class="ins-meta-val">${ins.margin}</div></div>
              <div class="ins-meta-item"><div class="ins-meta-lbl">Спринт</div><div class="ins-meta-val">№${ins.sprint}</div></div>
            </div>
          </div>
        </div>`).join('');
    } else {
      insHtml = `<div class="ins-item empty"><div class="ins-hd"><div class="ins-hd-l"><span class="ins-tag none">⚠ Инсайт не найден</span><span class="ins-title grey">Интервью не проводились — инсайт появится в следующем спринте</span></div></div></div>`;
    }

    // Checklist
    const clHtml = t.tasks.map(tk => `<div class="cl-item"><div class="cl-ico ${tk.done?'done':'fail'}">${tk.done?'✓':'✗'}</div><span>${tk.text}</span></div>`).join('');

    return `<div class="tc">
      <div class="tc-hd ${t.rankClass}">
        <span class="rank-pill ${t.rankClass}">${rankLabels[i]||i+1+' Место'}</span>
        <div class="tc-name">${t.name}</div>
      </div>
      <div class="tc-bd">
        <div class="mrow">
          <div class="mcell"><div class="mcell-lbl">Задачи</div><div class="mcell-val ${tCls}">${t.tasks_done}/${t.tasks_total}</div></div>
          <div class="mcell"><div class="mcell-lbl">Методология</div><div class="mcell-val ${dCls}">${t.dtbd_score}/10</div></div>
          <div class="mcell"><div class="mcell-lbl">Потенциал</div><div class="mcell-val ${pCls}">${pVal}</div></div>
        </div>
        <div class="mp"><div class="mp-row"><span class="mp-lbl">Задачи спринта</span><span class="mp-pct">${tPct}%</span></div><div class="mp-bg"><div class="mp-fill ${tBar}" style="width:${tPct}%"></div></div></div>
        <div class="mp"><div class="mp-row"><span class="mp-lbl">Следование методологии DTBD</span><span class="mp-pct">${dPct}%</span></div><div class="mp-bg"><div class="mp-fill ${dBar}" style="width:${dPct}%"></div></div></div>
        <div class="ins-block">${insHtml}</div>
        <div class="cl-ttl">Задачи спринта 1</div>
        ${clHtml}
        <div class="score-badge ${scoreCls}"><div class="score-num">${t.score} баллов</div><div class="score-sub">из 100 возможных</div></div>
      </div>
    </div>`;
  }).join('');

  // Footer & status
  const now = new Date();
  const ts = now.toLocaleDateString('ru-RU')+' '+now.toLocaleTimeString('ru-RU',{hour:'2-digit',minute:'2-digit'});
  document.getElementById('stxt').textContent = 'Обновлено: '+ts;
  document.getElementById('ftTxt').textContent = 'Данные из Google Sheets · '+ts+' · Потенциал = прибыль при захвате SOM, не текущая выручка';
}

// ── TOGGLE ────────────────────────────────────────────────────────────────────
function toggleIns(id) {
  const b = document.getElementById('ibody-'+id);
  const c = document.getElementById('chev-'+id);
  if(b){ b.classList.toggle('open'); if(c) c.classList.toggle('open'); }
}
function toggleCalc() {
  document.getElementById('calcPanel').classList.toggle('open');
}

// ── LOAD ──────────────────────────────────────────────────────────────────────
function loadData() {
  render(TEAMS);
}

loadData();
setInterval(loadData, 5*60*1000);
</script>
</body>
</html>
