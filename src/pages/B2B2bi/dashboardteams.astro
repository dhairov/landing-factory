---
// Beeline B2B GAP Dashboard v2 — Minimal White
// Data source: Google Sheets (public read, client-side fetch)
---
<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Beeline B2B · GAP Dashboard</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{
      --y:#FFD600;--yl:#FFFDE7;--ylm:#FFF9C4;
      --k:#0A0A0A;--g7:#333;--g5:#666;--g3:#CCC;--g1:#F5F5F5;--g05:#FAFAFA;--w:#FFF;
      --green:#00C853;--red:#FF3B30;
      --gold:#C9A227;--silver:#8A8A8A;--bronze:#A0522D;
      --r:12px;--rs:8px;
      --sh:0 1px 3px rgba(0,0,0,.08),0 1px 2px rgba(0,0,0,.04)
    }
    body{font-family:'Inter',-apple-system,sans-serif;background:var(--w);color:var(--k);min-height:100vh;-webkit-font-smoothing:antialiased}

    /* HEADER */
    .hd{background:var(--w);border-bottom:1px solid var(--g1);padding:0 40px;height:56px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100;box-shadow:0 1px 0 var(--g1)}
    .hd-l{display:flex;align-items:center;gap:12px}
    .logo{background:var(--y);color:var(--k);font-weight:800;font-size:13px;padding:4px 10px;border-radius:6px;letter-spacing:-.3px}
    .hd-t{font-size:14px;font-weight:500;color:var(--g5)}
    .hd-r{display:flex;align-items:center;gap:14px}
    .sdot{width:8px;height:8px;border-radius:50%;background:var(--green);display:inline-block}
    .stxt{font-size:12px;color:var(--g5)}
    .btn-r{background:var(--g1);border:none;border-radius:var(--rs);padding:6px 14px;font-size:13px;font-weight:500;color:var(--g7);cursor:pointer;transition:background .15s;font-family:inherit}
    .btn-r:hover{background:var(--g3)}

    /* LAYOUT */
    .main{max-width:1280px;margin:0 auto;padding:40px 40px 80px}

    /* KPI ROW */
    .kpi-row{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:40px}
    .kpi{border:1px solid var(--g1);border-radius:var(--r);padding:24px 24px 20px;background:var(--w);box-shadow:var(--sh)}
    .kpi.hl{border-color:var(--y);background:var(--yl)}
    .kpi-lbl{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.8px;color:var(--g5);margin-bottom:8px}
    .kpi-val{font-size:38px;font-weight:900;letter-spacing:-2px;line-height:1;color:var(--k)}
    .kpi-val.sm{font-size:26px;letter-spacing:-1px}
    .kpi-sub{font-size:12px;color:var(--g5);margin-top:6px}

    /* PROGRESS BLOCK */
    .prog-block{border:1px solid var(--g1);border-radius:var(--r);padding:28px 32px;background:var(--w);box-shadow:var(--sh);margin-bottom:40px}
    .prog-hd{display:flex;align-items:baseline;justify-content:space-between;margin-bottom:20px}
    .prog-lbl{font-size:14px;font-weight:500;color:var(--g7)}
    .prog-num{font-size:13px;color:var(--g5)}
    .prog-num strong{color:var(--k);font-weight:700}
    .track{height:8px;background:var(--g1);border-radius:100px;overflow:hidden;margin-bottom:16px}
    .fill{height:100%;background:var(--y);border-radius:100px;transition:width .8s cubic-bezier(.4,0,.2,1);min-width:2px}
    .prog-teams{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:4px}
    .pt-item{display:flex;flex-direction:column;gap:5px}
    .pt-name{font-size:12px;font-weight:500;color:var(--g7)}
    .pt-bar{height:4px;background:var(--g1);border-radius:100px;overflow:hidden}
    .pt-fill{height:100%;border-radius:100px}
    .pt-val{font-size:11px;color:var(--g5)}

    /* SECTION TITLE */
    .sec-t{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.8px;color:var(--g5);margin-bottom:16px}

    /* LEADERBOARD */
    .lb{border:1px solid var(--g1);border-radius:var(--r);background:var(--w);box-shadow:var(--sh);margin-bottom:40px;overflow:hidden}
    .lb-row{display:grid;grid-template-columns:48px 1fr 110px 110px 130px 90px;align-items:center;padding:18px 28px;border-bottom:1px solid var(--g1);gap:16px;transition:background .1s}
    .lb-row:last-child{border-bottom:none}
    .lb-row:hover{background:var(--g05)}
    .lb-row.r1{background:var(--yl)}
    .lb-row.r1:hover{background:var(--ylm)}
    .rnk{width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:800;flex-shrink:0}
    .r1 .rnk{background:var(--y);color:var(--k)}
    .r2 .rnk{background:var(--g1);color:var(--g7)}
    .r3 .rnk{background:#F5E6D3;color:var(--bronze)}
    .ti{min-width:0}
    .tn{font-size:15px;font-weight:700;color:var(--k);margin-bottom:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .tins{font-size:12px;color:var(--g5);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .tins.found{color:var(--green);font-weight:500}
    .mc{text-align:center}
    .mv{font-size:20px;font-weight:800;letter-spacing:-.5px;color:var(--k)}
    .ml{font-size:10px;text-transform:uppercase;letter-spacing:.5px;color:var(--g5);margin-top:2px}
    .sc{text-align:right}
    .sb{font-size:28px;font-weight:900;letter-spacing:-1px;color:var(--k)}
    .sm2{font-size:12px;color:var(--g3)}

    /* CARDS */
    .cards{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-bottom:40px}
    .card{border:1px solid var(--g1);border-radius:var(--r);background:var(--w);box-shadow:var(--sh);overflow:hidden}
    .card-hd{padding:18px 20px 14px;border-bottom:1px solid var(--g1)}
    .card-rank{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.8px;color:var(--g5);margin-bottom:3px}
    .card-name{font-size:17px;font-weight:800;color:var(--k);letter-spacing:-.3px}
    .card-bd{padding:16px 20px}
    .mrow{display:flex;align-items:center;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--g1)}
    .mrow:last-child{border-bottom:none}
    .mrow-l{display:flex;align-items:center;gap:8px;font-size:13px;color:var(--g5)}
    .mico{width:20px;height:20px;border-radius:4px;background:var(--g1);display:flex;align-items:center;justify-content:center;font-size:11px;flex-shrink:0}
    .mrow-v{font-size:14px;font-weight:700;color:var(--k)}
    .bm{height:3px;background:var(--g1);border-radius:100px;overflow:hidden;margin-top:3px}
    .bmf{height:100%;border-radius:100px;background:var(--y)}
    .bmf.g{background:var(--green)}
    .bmf.r{background:var(--red)}
    .ins-blk{margin:12px 0 0;padding:12px;background:var(--g05);border-radius:var(--rs);border-left:3px solid var(--y)}
    .ins-blk.empty{border-left-color:var(--g3)}
    .ins-tag{font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.6px;color:var(--g5);margin-bottom:4px}
    .ins-txt{font-size:13px;font-weight:600;color:var(--k);line-height:1.4}
    .ins-seg{font-size:12px;color:var(--g5);margin-top:3px}
    .tlist{margin-top:12px}
    .ti2{display:flex;align-items:flex-start;gap:6px;font-size:12px;color:var(--g5);padding:3px 0;line-height:1.4}
    .ti2.done{color:var(--g7)}
    .tck{width:14px;height:14px;border-radius:3px;border:1.5px solid var(--g3);flex-shrink:0;margin-top:1px;display:flex;align-items:center;justify-content:center;font-size:9px}
    .tck.done{background:var(--green);border-color:var(--green);color:#fff}

    /* TABLE */
    .tbl-wrap{border:1px solid var(--g1);border-radius:var(--r);background:var(--w);box-shadow:var(--sh);overflow:hidden}
    .tbl-wrap table{width:100%;border-collapse:collapse}
    .tbl-wrap thead th{padding:12px 18px;text-align:left;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;color:var(--g5);background:var(--g05);border-bottom:1px solid var(--g1);white-space:nowrap}
    .tbl-wrap tbody td{padding:14px 18px;font-size:13px;color:var(--k);border-bottom:1px solid var(--g1);vertical-align:top}
    .tbl-wrap tbody tr:last-child td{border-bottom:none}
    .tbl-wrap tbody tr:hover td{background:var(--g05)}
    .tbl-wrap tbody tr.tr1 td{background:var(--yl)}
    .tbl-wrap tbody tr.tr1:hover td{background:var(--ylm)}
    .tag{display:inline-block;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600}
    .tg{background:#E8F5E9;color:#2E7D32}
    .tgr{background:var(--g1);color:var(--g5)}
    .spill{display:inline-flex;align-items:center;justify-content:center;width:34px;height:34px;border-radius:50%;font-size:14px;font-weight:800}
    .spill.hi{background:var(--y);color:var(--k)}
    .spill.lo{background:var(--g1);color:var(--g5)}

    /* LOADING */
    .lov{position:fixed;inset:0;background:var(--w);display:flex;align-items:center;justify-content:center;z-index:999;transition:opacity .3s}
    .lov.hidden{opacity:0;pointer-events:none}
    .spin{width:32px;height:32px;border:3px solid var(--g1);border-top-color:var(--y);border-radius:50%;animation:sp .7s linear infinite}
    @keyframes sp{to{transform:rotate(360deg)}}

    /* FOOTER */
    .ft{border-top:1px solid var(--g1);padding:18px 40px;display:flex;align-items:center;justify-content:space-between}
    .ft-l{font-size:12px;color:var(--g5)}
    .ft-a{font-size:12px;color:var(--g5);text-decoration:none;border-bottom:1px solid var(--g3)}
    .ft-a:hover{color:var(--k);border-color:var(--k)}

    @media(max-width:900px){
      .main{padding:24px 20px 60px}
      .kpi-row{grid-template-columns:repeat(2,1fr)}
      .cards{grid-template-columns:1fr}
      .lb-row{grid-template-columns:40px 1fr 80px 80px}
      .lb-row .mc:nth-child(5),.lb-row .sc{display:none}
      .hd{padding:0 20px}
      .ft{padding:16px 20px}
    }
  </style>
</head>
<body>

<div class="lov" id="lov"><div class="spin"></div></div>

<header class="hd">
  <div class="hd-l">
    <span class="logo">beeline</span>
    <span class="hd-t">B2B &middot; GAP Dashboard</span>
  </div>
  <div class="hd-r">
    <span class="sdot" id="sdot"></span>
    <span class="stxt" id="stxt">Загрузка&hellip;</span>
    <button class="btn-r" onclick="loadData()">&#8635; Обновить</button>
  </div>
</header>

<main class="main">

  <div class="kpi-row">
    <div class="kpi hl">
      <div class="kpi-lbl">Цель GAP (Grinbox)</div>
      <div class="kpi-val sm">2,7 млрд ₽</div>
      <div class="kpi-sub">B2B-направление &middot; DTBD</div>
    </div>
    <div class="kpi">
      <div class="kpi-lbl">Потенциал закрытия</div>
      <div class="kpi-val sm" id="kPot">—</div>
      <div class="kpi-sub" id="kPotPct">от цели</div>
    </div>
    <div class="kpi">
      <div class="kpi-lbl">Супер-инсайтов</div>
      <div class="kpi-val" id="kIns">—</div>
      <div class="kpi-sub">найдено командами</div>
    </div>
    <div class="kpi">
      <div class="kpi-lbl">Текущий спринт</div>
      <div class="kpi-val" id="kSpr">—</div>
      <div class="kpi-sub">неделя программы</div>
    </div>
  </div>

  <div class="prog-block">
    <div class="prog-hd">
      <span class="prog-lbl">Прогресс закрытия GAP</span>
      <span class="prog-num"><strong id="pClosed">—</strong> из 2 700 000 000 ₽</span>
    </div>
    <div class="track"><div class="fill" id="mFill" style="width:0%"></div></div>
    <div class="prog-teams" id="pTeams"></div>
  </div>

  <div class="sec-t">Рейтинг команд &middot; Спринт <span id="spLbl">—</span></div>
  <div class="lb" id="lbBody"></div>

  <div class="sec-t" style="margin-top:40px">Детали по командам</div>
  <div class="cards" id="cardsGrid"></div>

  <div class="sec-t">Сводная таблица</div>
  <div class="tbl-wrap">
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Команда</th>
          <th>Супер-инсайт</th>
          <th>Сегмент + Ценность</th>
          <th>Потенциал рынка</th>
          <th>Задачи спринта</th>
          <th>Методология DTBD</th>
        </tr>
      </thead>
      <tbody id="tblBody"></tbody>
    </table>
  </div>

</main>

<footer class="ft">
  <span class="ft-l">Данные из Google Sheets &middot; <span id="lupd">—</span></span>
  <a href="https://docs.google.com/spreadsheets/d/18VrhTHQPdVgxVZZF3is3Ozce56rpY-j-wmikH8Dpy08/edit" target="_blank" class="ft-a">Редактировать данные →</a>
</footer>

<script>
const SID="18VrhTHQPdVgxVZZF3is3Ozce56rpY-j-wmikH8Dpy08";
const GAP=2700000000;
const TASKS=["Определены сегменты ЦА и критерии поиска респондентов","Определены интервьюеры","Назначены 3–5 интервью с клиентами","Проведены пробные интервью (мин. 2 шт.)","Транскрибации отправлены эксперту","Встреча с экспертом для обратной связи"];
const TC=["#C9A227","#8A8A8A","#A0522D"];
const MED=["🥇","🥈","🥉"];
const RLBL=["1 место","2 место","3 место"];

function fmt(n){
  if(!n||isNaN(n))return"—";
  if(n>=1e9)return(n/1e9).toFixed(1).replace(".0","")+" млрд ₽";
  if(n>=1e6)return Math.round(n/1e6)+" млн ₽";
  if(n>=1e3)return Math.round(n/1e3)+" тыс ₽";
  return n+" ₽";
}
function pot(r){
  const ex=parseFloat(r.market_potential_rub);
  if(ex&&ex>0)return ex;
  const ch=parseFloat(r.avg_check)||0;
  const mg=parseFloat(r.marginality)||100;
  if(!ch)return 0;
  return ch*12*1000*(mg/100);
}
function score(r){
  const m=parseFloat(r.methodology_score)||0;
  const td=parseInt(r.tasks_done)||0;
  const tt=parseInt(r.tasks_total)||6;
  const hi=r.super_insight_title&&r.super_insight_title!=="—"&&r.super_insight_title.trim()!=="";
  return Math.round((m/10)*40+(tt>0?(td/tt)*40:0)+(hi?20:0));
}
function hasIns(r){return r.super_insight_title&&r.super_insight_title!=="—"&&r.super_insight_title.trim()!=="";}

async function loadData(){
  try{
    const res=await fetch("https://docs.google.com/spreadsheets/d/"+SID+"/gviz/tq?tqx=out:json&sheet=Teams");
    const txt=await res.text();
    const json=JSON.parse(txt.substring(47).slice(0,-2));
    const cols=json.table.cols.map(c=>c.label);
    const rows=json.table.rows.map(r=>{
      const o={};
      r.c.forEach((c,i)=>{o[cols[i]]=c?(c.v!==null?c.v:""):"";});
      return o;
    }).filter(r=>r.team_id);
    render(rows);
    document.getElementById("sdot").style.background="#00C853";
    document.getElementById("stxt").textContent="Обновлено: "+new Date().toLocaleTimeString("ru",{hour:"2-digit",minute:"2-digit"});
    document.getElementById("lupd").textContent=new Date().toLocaleString("ru",{day:"2-digit",month:"2-digit",hour:"2-digit",minute:"2-digit"});
  }catch(e){
    document.getElementById("sdot").style.background="#FF3B30";
    document.getElementById("stxt").textContent="Ошибка загрузки";
    console.error(e);
  }finally{
    const ov=document.getElementById("lov");
    ov.classList.add("hidden");
    setTimeout(()=>ov.remove(),400);
  }
}

function render(rows){
  const scored=rows.map(r=>({...r,_s:score(r),_p:pot(r)})).sort((a,b)=>b._s-a._s);
  const sprint=scored[0]?scored[0].sprint||1:1;
  const totP=scored.reduce((s,r)=>s+r._p,0);
  const totI=scored.filter(r=>hasIns(r)).length;
  const pct=Math.min(100,(totP/GAP*100)).toFixed(1);

  document.getElementById("kPot").textContent=fmt(totP);
  document.getElementById("kPotPct").textContent=pct+"% от цели";
  document.getElementById("kIns").textContent=totI;
  document.getElementById("kSpr").textContent=sprint;
  document.getElementById("spLbl").textContent=sprint;
  document.getElementById("pClosed").textContent=fmt(totP);
  document.getElementById("mFill").style.width=Math.max(.5,parseFloat(pct))+"%";

  document.getElementById("pTeams").innerHTML=scored.map(function(r,i){
    const tp=Math.min(100,(r._p/GAP*100)).toFixed(2);
    return'<div class="pt-item"><div class="pt-name">'+( r.team_name||r.team_id)+'</div><div class="pt-bar"><div class="pt-fill" style="width:'+Math.max(.5,tp)+'%;background:'+TC[i]+'"></div></div><div class="pt-val">'+fmt(r._p)+'</div></div>';
  }).join("");

  document.getElementById("lbBody").innerHTML=scored.map(function(r,i){
    const hi=hasIns(r);
    const td=parseInt(r.tasks_done)||0,tt=parseInt(r.tasks_total)||6;
    const m=parseFloat(r.methodology_score)||0;
    return'<div class="lb-row r'+(i+1)+'">'
      +'<div class="rnk">'+MED[i]+'</div>'
      +'<div class="ti"><div class="tn">'+(r.team_name||r.team_id)+'</div><div class="tins'+(hi?' found':'')+'">'+( hi?'⚡ '+r.super_insight_title:'Супер-инсайт ещё не найден')+'</div></div>'
      +'<div class="mc"><div class="mv">'+td+'/'+tt+'</div><div class="ml">Задачи</div></div>'
      +'<div class="mc"><div class="mv">'+m+'/10</div><div class="ml">DTBD</div></div>'
      +'<div class="mc"><div class="mv">'+fmt(r._p)+'</div><div class="ml">Потенциал</div></div>'
      +'<div class="sc"><div class="sb">'+r._s+'</div><div class="sm2">/100</div></div>'
      +'</div>';
  }).join("");

  document.getElementById("cardsGrid").innerHTML=scored.map(function(r,i){
    const hi=hasIns(r);
    const td=parseInt(r.tasks_done)||0,tt=parseInt(r.tasks_total)||6;
    const m=parseFloat(r.methodology_score)||0;
    const tp=tt>0?Math.round(td/tt*100):0;
    const mp=Math.round(m/10*100);
    const tc2=tp>=60?'g':tp>=30?'':'r';
    const mc2=mp>=60?'g':mp>=30?'':'r';
    const thtml=TASKS.map(function(t,ti){
      const d=ti<td;
      return'<div class="ti2'+(d?' done':'')+'"><div class="tck'+(d?' done':'')+'">'+( d?'✓':'')+'</div><span>'+t+'</span></div>';
    }).join('');
    return'<div class="card">'
      +'<div class="card-hd" style="border-top:3px solid '+TC[i]+'">'
      +'<div class="card-rank">'+RLBL[i]+' &middot; '+r._s+' баллов</div>'
      +'<div class="card-name">'+(r.team_name||r.team_id)+'</div>'
      +'</div>'
      +'<div class="card-bd">'
      +'<div class="mrow"><div class="mrow-l"><div class="mico">✓</div>Задачи спринта</div><div class="mrow-v">'+td+'/'+tt+'</div></div>'
      +'<div class="bm"><div class="bmf '+tc2+'" style="width:'+tp+'%"></div></div>'
      +'<div class="mrow" style="margin-top:8px"><div class="mrow-l"><div class="mico">★</div>Методология DTBD</div><div class="mrow-v">'+m+'/10</div></div>'
      +'<div class="bm"><div class="bmf '+mc2+'" style="width:'+mp+'%"></div></div>'
      +'<div class="mrow" style="margin-top:8px"><div class="mrow-l"><div class="mico">₽</div>Потенциал рынка</div><div class="mrow-v">'+fmt(r._p)+'</div></div>'
      +'<div class="ins-blk'+(hi?'':' empty')+'">'
      +'<div class="ins-tag">'+(hi?'⚡ Супер-инсайт':'Инсайт не найден')+'</div>'
      +(hi?'<div class="ins-txt">'+r.super_insight_title+'</div><div class="ins-seg">'+(r.super_insight_core_job||'')+'</div><div class="ins-seg">'+(r.super_insight_target||'')+'</div>':'<div class="ins-txt" style="color:var(--g3)">Ожидается на следующей неделе</div>')
      +'</div>'
      +'<div class="tlist">'+thtml+'</div>'
      +'</div></div>';
  }).join("");

  document.getElementById("tblBody").innerHTML=scored.map(function(r,i){
    const hi=hasIns(r);
    const td=parseInt(r.tasks_done)||0,tt=parseInt(r.tasks_total)||6;
    const m=parseFloat(r.methodology_score)||0;
    return'<tr class="'+(i===0?'tr1':'')+'">'
      +'<td><strong>'+MED[i]+'</strong></td>'
      +'<td><strong>'+(r.team_name||r.team_id)+'</strong></td>'
      +'<td>'+(hi?'<span class="tag tg">⚡ '+r.super_insight_title+'</span>':'<span class="tag tgr">Не найден</span>')+'</td>'
      +'<td>'+(r.super_insight_target?'<div style="font-size:12px">'+r.super_insight_target+'</div><div style="font-size:11px;color:var(--g5);margin-top:2px">'+(r.avg_check?r.avg_check+' ₽/мес · маржа '+(r.marginality||100)+'%':'')+'</div>':'—')+'</td>'
      +'<td><strong>'+fmt(r._p)+'</strong></td>'
      +'<td>'+td+'/'+tt+'</td>'
      +'<td><span class="spill '+(m>=5?'hi':'lo')+'">'+m+'</span></td>'
      +'</tr>';
  }).join("");
}

loadData();
setInterval(loadData,300000);
</script>
</body>
</html>
