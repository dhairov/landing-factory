---
// Beeline B2B GAP Dashboard — Sprint Tracker
// Data source: Google Sheets (public read)
const SHEET_ID = "18VrhTHQPdVgxVZZF3is3Ozce56rpY-j-wmikH8Dpy08";
const SHEET_NAME = "Teams";
const GAP_TARGET = 2700000000; // 2.7 млрд руб.
---
<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Beeline B2B | GAP Dashboard — Трекер спринтов</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg: #0d0f14;
      --surface: #161a24;
      --surface2: #1e2333;
      --border: #2a3045;
      --accent: #f5a623;
      --accent2: #e8392a;
      --green: #22c55e;
      --yellow: #f5a623;
      --red: #ef4444;
      --blue: #3b82f6;
      --text: #f0f2f8;
      --text-muted: #8892a4;
      --text-dim: #4a5568;
      --beeline-yellow: #FFD600;
      --beeline-dark: #1a1a1a;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      line-height: 1.5;
    }

    /* ── HEADER ── */
    .header {
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      padding: 16px 32px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .header-left {
      display: flex;
      align-items: center;
      gap: 16px;
    }
    .logo-badge {
      background: var(--beeline-yellow);
      color: #000;
      font-weight: 800;
      font-size: 13px;
      padding: 6px 12px;
      border-radius: 6px;
      letter-spacing: 0.5px;
    }
    .header-title {
      font-size: 15px;
      font-weight: 600;
      color: var(--text);
    }
    .header-sub {
      font-size: 12px;
      color: var(--text-muted);
      margin-top: 1px;
    }
    .header-right {
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .live-badge {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 12px;
      color: var(--green);
      font-weight: 500;
    }
    .live-dot {
      width: 7px;
      height: 7px;
      background: var(--green);
      border-radius: 50%;
      animation: pulse 2s infinite;
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.4; }
    }
    .refresh-btn {
      background: var(--surface2);
      border: 1px solid var(--border);
      color: var(--text-muted);
      padding: 6px 14px;
      border-radius: 6px;
      font-size: 12px;
      cursor: pointer;
      font-family: 'Inter', sans-serif;
      transition: all 0.2s;
    }
    .refresh-btn:hover { color: var(--text); border-color: var(--accent); }

    /* ── MAIN ── */
    .main { padding: 32px; max-width: 1400px; margin: 0 auto; }

    /* ── GAP HERO ── */
    .gap-hero {
      background: linear-gradient(135deg, #1a1f2e 0%, #0f1520 100%);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 32px 40px;
      margin-bottom: 32px;
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 32px;
      align-items: center;
    }
    .gap-label {
      font-size: 11px;
      font-weight: 600;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 1.5px;
      margin-bottom: 8px;
    }
    .gap-title {
      font-size: 28px;
      font-weight: 800;
      color: var(--text);
      line-height: 1.2;
      margin-bottom: 6px;
    }
    .gap-title span { color: var(--beeline-yellow); }
    .gap-subtitle {
      font-size: 14px;
      color: var(--text-muted);
      max-width: 600px;
    }
    .gap-stats {
      display: flex;
      gap: 24px;
    }
    .gap-stat {
      text-align: center;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 16px 24px;
      min-width: 140px;
    }
    .gap-stat-value {
      font-size: 26px;
      font-weight: 800;
      color: var(--beeline-yellow);
      line-height: 1;
      margin-bottom: 4px;
    }
    .gap-stat-label {
      font-size: 11px;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.8px;
    }

    /* ── OVERALL PROGRESS ── */
    .overall-section {
      margin-bottom: 32px;
    }
    .section-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 16px;
    }
    .section-title {
      font-size: 16px;
      font-weight: 700;
      color: var(--text);
    }
    .section-badge {
      font-size: 11px;
      color: var(--text-muted);
      background: var(--surface2);
      border: 1px solid var(--border);
      padding: 4px 10px;
      border-radius: 20px;
    }
    .overall-bar-wrap {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 24px 28px;
    }
    .overall-bar-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      margin-bottom: 12px;
    }
    .overall-bar-label {
      font-size: 13px;
      color: var(--text-muted);
    }
    .overall-bar-value {
      font-size: 22px;
      font-weight: 800;
      color: var(--beeline-yellow);
    }
    .overall-bar-value span {
      font-size: 13px;
      font-weight: 400;
      color: var(--text-muted);
      margin-left: 6px;
    }
    .progress-track {
      background: var(--surface2);
      border-radius: 8px;
      height: 14px;
      overflow: hidden;
      position: relative;
    }
    .progress-fill {
      height: 100%;
      border-radius: 8px;
      transition: width 1s ease;
      position: relative;
    }
    .progress-fill::after {
      content: '';
      position: absolute;
      top: 0; right: 0; bottom: 0;
      width: 40px;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15));
    }

    /* ── TEAM CARDS GRID ── */
    .teams-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
      margin-bottom: 32px;
    }
    @media (max-width: 1100px) {
      .teams-grid { grid-template-columns: 1fr; }
      .gap-hero { grid-template-columns: 1fr; }
      .gap-stats { justify-content: flex-start; flex-wrap: wrap; }
    }

    .team-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 16px;
      overflow: hidden;
      transition: border-color 0.2s, transform 0.2s;
    }
    .team-card:hover {
      border-color: var(--accent);
      transform: translateY(-2px);
    }
    .team-card.rank-1 { border-top: 3px solid #FFD700; }
    .team-card.rank-2 { border-top: 3px solid #C0C0C0; }
    .team-card.rank-3 { border-top: 3px solid #CD7F32; }

    .team-card-header {
      padding: 20px 24px 16px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
    }
    .team-rank {
      font-size: 28px;
      font-weight: 800;
      line-height: 1;
      min-width: 36px;
    }
    .rank-1 .team-rank { color: #FFD700; }
    .rank-2 .team-rank { color: #C0C0C0; }
    .rank-3 .team-rank { color: #CD7F32; }

    .team-name {
      font-size: 14px;
      font-weight: 700;
      color: var(--text);
      line-height: 1.3;
      flex: 1;
    }
    .team-sprint-badge {
      font-size: 11px;
      color: var(--text-muted);
      background: var(--surface2);
      border: 1px solid var(--border);
      padding: 3px 8px;
      border-radius: 20px;
      white-space: nowrap;
    }

    .team-card-body { padding: 20px 24px; }

    /* Score row */
    .score-row {
      display: flex;
      gap: 12px;
      margin-bottom: 20px;
    }
    .score-item {
      flex: 1;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 12px 14px;
      text-align: center;
    }
    .score-value {
      font-size: 20px;
      font-weight: 800;
      line-height: 1;
      margin-bottom: 4px;
    }
    .score-label {
      font-size: 10px;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.6px;
    }

    /* Metric rows */
    .metric-row {
      display: flex;
      flex-direction: column;
      gap: 12px;
      margin-bottom: 20px;
    }
    .metric-item {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .metric-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .metric-label {
      font-size: 11px;
      font-weight: 600;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.8px;
    }
    .metric-value-sm {
      font-size: 12px;
      font-weight: 600;
      color: var(--text);
    }
    .mini-track {
      background: var(--surface2);
      border-radius: 4px;
      height: 6px;
      overflow: hidden;
    }
    .mini-fill {
      height: 100%;
      border-radius: 4px;
      transition: width 1s ease;
    }

    /* Insight block */
    .insight-block {
      background: var(--surface2);
      border: 1px solid var(--border);
      border-left: 3px solid var(--accent);
      border-radius: 0 10px 10px 0;
      padding: 14px 16px;
      margin-bottom: 16px;
    }
    .insight-label {
      font-size: 10px;
      font-weight: 700;
      color: var(--accent);
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 6px;
    }
    .insight-title {
      font-size: 13px;
      font-weight: 600;
      color: var(--text);
      margin-bottom: 4px;
      line-height: 1.4;
    }
    .insight-core-job {
      font-size: 12px;
      color: var(--text-muted);
      line-height: 1.4;
      margin-bottom: 4px;
    }
    .insight-target {
      font-size: 11px;
      color: var(--text-dim);
      font-style: italic;
    }
    .no-insight {
      background: var(--surface2);
      border: 1px dashed var(--border);
      border-radius: 10px;
      padding: 14px 16px;
      margin-bottom: 16px;
      text-align: center;
      color: var(--text-dim);
      font-size: 12px;
    }

    /* Tasks checklist */
    .tasks-section { }
    .tasks-label {
      font-size: 11px;
      font-weight: 600;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.8px;
      margin-bottom: 10px;
      display: flex;
      justify-content: space-between;
    }
    .tasks-counter {
      color: var(--text);
      font-weight: 700;
    }
    .task-list {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .task-item {
      display: flex;
      align-items: flex-start;
      gap: 8px;
      font-size: 12px;
      line-height: 1.4;
    }
    .task-check {
      width: 16px;
      height: 16px;
      border-radius: 4px;
      flex-shrink: 0;
      margin-top: 1px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 10px;
    }
    .task-check.done {
      background: var(--green);
      color: #fff;
    }
    .task-check.pending {
      background: var(--surface2);
      border: 1px solid var(--border);
      color: transparent;
    }
    .task-text.done { color: var(--text); }
    .task-text.pending { color: var(--text-dim); }

    /* ── MAIN TABLE ── */
    .table-section { margin-bottom: 32px; }
    .table-wrap {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 16px;
      overflow: hidden;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 13px;
    }
    thead tr {
      background: var(--surface2);
      border-bottom: 1px solid var(--border);
    }
    th {
      padding: 14px 16px;
      text-align: left;
      font-size: 10px;
      font-weight: 700;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 1px;
      white-space: nowrap;
    }
    td {
      padding: 16px 16px;
      border-bottom: 1px solid var(--border);
      vertical-align: top;
    }
    tbody tr:last-child td { border-bottom: none; }
    tbody tr:hover { background: rgba(255,255,255,0.02); }

    .td-team { font-weight: 700; color: var(--text); min-width: 160px; }
    .td-insight { max-width: 220px; }
    .td-insight-title { font-weight: 600; color: var(--text); margin-bottom: 3px; }
    .td-insight-sub { font-size: 11px; color: var(--text-muted); line-height: 1.4; }
    .td-segment { max-width: 200px; }
    .td-segment-name { font-weight: 600; color: var(--text); margin-bottom: 3px; }
    .td-segment-sub { font-size: 11px; color: var(--text-muted); }
    .td-market { text-align: right; min-width: 120px; }
    .td-market-val { font-weight: 700; color: var(--beeline-yellow); font-size: 14px; }
    .td-market-sub { font-size: 11px; color: var(--text-muted); margin-top: 2px; }
    .td-tasks { min-width: 100px; }
    .td-method { min-width: 120px; }

    .pill {
      display: inline-block;
      padding: 3px 10px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 600;
    }
    .pill-red { background: rgba(239,68,68,0.15); color: #ef4444; }
    .pill-yellow { background: rgba(245,166,35,0.15); color: #f5a623; }
    .pill-green { background: rgba(34,197,94,0.15); color: #22c55e; }

    .method-bar-wrap { display: flex; align-items: center; gap: 8px; }
    .method-score { font-weight: 700; font-size: 14px; min-width: 28px; }
    .method-track {
      flex: 1;
      background: var(--surface2);
      border-radius: 4px;
      height: 6px;
      overflow: hidden;
    }
    .method-fill {
      height: 100%;
      border-radius: 4px;
    }

    /* ── FOOTER ── */
    .footer {
      border-top: 1px solid var(--border);
      padding: 20px 32px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 12px;
      color: var(--text-dim);
    }
    .footer a {
      color: var(--text-muted);
      text-decoration: none;
    }
    .footer a:hover { color: var(--beeline-yellow); }

    /* Loading state */
    .loading {
      text-align: center;
      padding: 80px 32px;
      color: var(--text-muted);
    }
    .spinner {
      width: 36px;
      height: 36px;
      border: 3px solid var(--border);
      border-top-color: var(--beeline-yellow);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      margin: 0 auto 16px;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    .error-msg {
      background: rgba(239,68,68,0.1);
      border: 1px solid rgba(239,68,68,0.3);
      border-radius: 10px;
      padding: 16px 20px;
      color: #ef4444;
      font-size: 13px;
      margin: 20px 0;
    }

    /* Potential pie */
    .pie-section {
      margin-bottom: 32px;
    }
    .pie-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 16px;
    }
    @media (max-width: 900px) { .pie-grid { grid-template-columns: 1fr; } }
    .pie-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 20px 24px;
    }
    .pie-card-title {
      font-size: 12px;
      font-weight: 600;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.8px;
      margin-bottom: 12px;
    }
    .pie-bar-row {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 8px;
    }
    .pie-bar-label {
      font-size: 12px;
      color: var(--text-muted);
      min-width: 130px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .pie-bar-track {
      flex: 1;
      background: var(--surface2);
      border-radius: 4px;
      height: 8px;
      overflow: hidden;
    }
    .pie-bar-fill {
      height: 100%;
      border-radius: 4px;
    }
    .pie-bar-val {
      font-size: 12px;
      font-weight: 700;
      color: var(--text);
      min-width: 40px;
      text-align: right;
    }
  </style>
</head>
<body>

<!-- HEADER -->
<header class="header">
  <div class="header-left">
    <div class="logo-badge">beeline</div>
    <div>
      <div class="header-title">B2B GAP Dashboard</div>
      <div class="header-sub">Трекер спринтов · Программа поиска прибыли</div>
    </div>
  </div>
  <div class="header-right">
    <div class="live-badge">
      <div class="live-dot"></div>
      <span id="last-updated">Загрузка...</span>
    </div>
    <button class="refresh-btn" onclick="loadData()">↻ Обновить</button>
  </div>
</header>

<!-- MAIN -->
<main class="main">

  <!-- GAP HERO -->
  <div class="gap-hero">
    <div>
      <div class="gap-label">Цель программы · B2B-направление</div>
      <div class="gap-title">Закрыть <span>GAP (Grinbox)</span> по прибыли</div>
      <div class="gap-subtitle">
        Найти продуктовые инициативы через новые сегменты и переупаковку продуктов,
        суммарно закрывающие недостающую прибыль B2B-направления. Методология: DTBD.
      </div>
    </div>
    <div class="gap-stats">
      <div class="gap-stat">
        <div class="gap-stat-value">2,7 млрд</div>
        <div class="gap-stat-label">Цель (руб.)</div>
      </div>
      <div class="gap-stat">
        <div class="gap-stat-value" id="stat-sprint">—</div>
        <div class="gap-stat-label">Текущий спринт</div>
      </div>
      <div class="gap-stat">
        <div class="gap-stat-value" id="stat-insights">—</div>
        <div class="gap-stat-label">Супер-инсайтов</div>
      </div>
    </div>
  </div>

  <!-- LOADING / ERROR -->
  <div id="loading-state" class="loading">
    <div class="spinner"></div>
    <div>Загрузка данных из Google Sheets...</div>
  </div>
  <div id="error-state" class="error-msg" style="display:none;"></div>

  <!-- DYNAMIC CONTENT -->
  <div id="dashboard-content" style="display:none;">

    <!-- OVERALL PROGRESS -->
    <div class="overall-section">
      <div class="section-header">
        <div class="section-title">Общий потенциал закрытия GAP</div>
        <div class="section-badge" id="overall-pct-badge">0% от цели</div>
      </div>
      <div class="overall-bar-wrap">
        <div class="overall-bar-header">
          <div class="overall-bar-label">Суммарный потенциал всех команд</div>
          <div class="overall-bar-value" id="overall-value">0 ₽ <span>из 2 700 000 000 ₽</span></div>
        </div>
        <div class="progress-track">
          <div class="progress-fill" id="overall-bar" style="width:0%; background: linear-gradient(90deg, #FFD600, #f5a623);"></div>
        </div>
      </div>
    </div>

    <!-- POTENTIAL BREAKDOWN -->
    <div class="pie-section">
      <div class="section-header">
        <div class="section-title">Вклад команд в закрытие GAP</div>
        <div class="section-badge">Оценка потенциала по методике</div>
      </div>
      <div class="pie-grid" id="pie-grid">
        <!-- filled by JS -->
      </div>
    </div>

    <!-- TEAM CARDS -->
    <div class="section-header">
      <div class="section-title">Рейтинг команд · Спринт <span id="sprint-label">1</span></div>
      <div class="section-badge">Сортировка по общему баллу</div>
    </div>
    <div class="teams-grid" id="teams-grid">
      <!-- filled by JS -->
    </div>

    <!-- MAIN TABLE -->
    <div class="table-section">
      <div class="section-header">
        <div class="section-title">Сводная таблица результатов</div>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>#</th>
              <th>Команда</th>
              <th>Супер-инсайт</th>
              <th>Сегмент + Ценность</th>
              <th>Потенциал рынка</th>
              <th>Задачи спринта</th>
              <th>Методология</th>
            </tr>
          </thead>
          <tbody id="main-table-body">
            <!-- filled by JS -->
          </tbody>
        </table>
      </div>
    </div>

  </div><!-- /dashboard-content -->
</main>

<!-- FOOTER -->
<footer class="footer">
  <div>beeline B2B · Программа поиска GAP-прибыли · DTBD-методология</div>
  <div>
    <a href="https://docs.google.com/spreadsheets/d/18VrhTHQPdVgxVZZF3is3Ozce56rpY-j-wmikH8Dpy08/edit" target="_blank">
      Редактировать данные в Google Sheets →
    </a>
  </div>
</footer>

<script>
  const SHEET_ID = "18VrhTHQPdVgxVZZF3is3Ozce56rpY-j-wmikH8Dpy08";
  const SHEET_NAME = "Teams";
  const GAP_TARGET = 2_700_000_000;

  const TASK_NAMES = [
    "Определены сегменты ЦА и критерии поиска респондентов",
    "Определены интервьюеры",
    "Назначены 3–5 интервью с клиентами",
    "Проведены пробные интервью (мин. 2 шт.)",
    "Транскрибации отправлены эксперту",
    "Встреча с экспертом для обратной связи"
  ];

  const TEAM_COLORS = ["#FFD700", "#C0C0C0", "#CD7F32"];
  const BAR_COLORS = ["#FFD600", "#3b82f6", "#22c55e"];

  function formatRub(n) {
    if (!n || isNaN(n)) return "—";
    if (n >= 1_000_000_000) return (n / 1_000_000_000).toFixed(1) + " млрд ₽";
    if (n >= 1_000_000) return (n / 1_000_000).toFixed(0) + " млн ₽";
    if (n >= 1_000) return (n / 1_000).toFixed(0) + " тыс. ₽";
    return n.toLocaleString("ru") + " ₽";
  }

  function calcPotential(row) {
    // Методика оценки потенциала:
    // Потенциал = Средний чек × 12 мес × Оценка рынка (кол-во клиентов) × Вероятность × Маржинальность/100
    // Если market_potential_rub задан явно — используем его
    // Иначе оцениваем по среднему чеку и маржинальности
    const marketPotential = parseFloat(row.market_potential_rub) || 0;
    if (marketPotential > 0) return marketPotential;

    const avgCheck = parseFloat(row.avg_check) || 0;
    const margin = parseFloat(row.marginality) || 0;
    const methodScore = parseFloat(row.methodology_score) || 0;
    const tasksDone = parseFloat(row.tasks_done) || 0;
    const tasksTotal = parseFloat(row.tasks_total) || 1;

    if (avgCheck === 0) return 0;

    // Базовая оценка: предполагаем 1000 клиентов в сегменте как стартовая гипотеза
    // Вероятность = (методология/10 × 0.5) + (выполнение задач × 0.5)
    const taskPct = tasksDone / tasksTotal;
    const probability = ((methodScore / 10) * 0.5 + taskPct * 0.5) * 0.3; // макс 30% вероятность на старте
    const estimatedClients = 1000;
    return Math.round(avgCheck * 12 * estimatedClients * probability * (margin / 100));
  }

  function getMethodColor(score) {
    if (score >= 7) return "#22c55e";
    if (score >= 4) return "#f5a623";
    return "#ef4444";
  }

  function getTaskPill(done, total) {
    const pct = total > 0 ? done / total : 0;
    if (pct >= 0.8) return `<span class="pill pill-green">${done}/${total}</span>`;
    if (pct >= 0.4) return `<span class="pill pill-yellow">${done}/${total}</span>`;
    return `<span class="pill pill-red">${done}/${total}</span>`;
  }

  async function loadData() {
    document.getElementById("loading-state").style.display = "block";
    document.getElementById("dashboard-content").style.display = "none";
    document.getElementById("error-state").style.display = "none";

    try {
      const url = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:json&sheet=${encodeURIComponent(SHEET_NAME)}`;
      const res = await fetch(url);
      const text = await res.text();
      // Google wraps response in google.visualization.Query.setResponse(...)
      const json = JSON.parse(text.match(/google\.visualization\.Query\.setResponse\(([\s\S]*)\)/)[1]);

      const cols = json.table.cols.map(c => c.label || c.id);
      const rows = json.table.rows.map(r => {
        const obj = {};
        r.c.forEach((cell, i) => {
          obj[cols[i]] = cell ? (cell.v !== null ? cell.v : "") : "";
        });
        return obj;
      });

      // Skip header row if it's a string row
      const dataRows = rows.filter(r => r.team_id && !isNaN(parseFloat(r.team_id)));

      renderDashboard(dataRows);

      document.getElementById("last-updated").textContent =
        "Обновлено: " + new Date().toLocaleTimeString("ru-RU", {hour: "2-digit", minute: "2-digit"});
      document.getElementById("loading-state").style.display = "none";
      document.getElementById("dashboard-content").style.display = "block";

    } catch (e) {
      document.getElementById("loading-state").style.display = "none";
      document.getElementById("error-state").style.display = "block";
      document.getElementById("error-state").textContent =
        "Ошибка загрузки данных: " + e.message + ". Проверьте доступ к Google Sheets.";
    }
  }

  function renderDashboard(rows) {
    // Compute potentials and scores
    rows.forEach(r => {
      r._potential = calcPotential(r);
      const tasksDone = parseFloat(r.tasks_done) || 0;
      const tasksTotal = parseFloat(r.tasks_total) || 1;
      const methodScore = parseFloat(r.methodology_score) || 0;
      const hasInsight = r.super_insight_title && r.super_insight_title !== "—" ? 1 : 0;
      // Composite score: tasks 40% + methodology 40% + insight 20%
      r._score = (tasksDone / tasksTotal) * 40 + (methodScore / 10) * 40 + hasInsight * 20;
    });

    // Sort by score descending
    const sorted = [...rows].sort((a, b) => b._score - a._score);

    // Stats
    const totalPotential = rows.reduce((s, r) => s + r._potential, 0);
    const insightsCount = rows.filter(r => r.super_insight_title && r.super_insight_title !== "—").length;
    const sprint = rows[0]?.sprint || "1";

    document.getElementById("stat-sprint").textContent = sprint;
    document.getElementById("stat-insights").textContent = insightsCount;
    document.getElementById("sprint-label").textContent = sprint;

    // Overall bar
    const overallPct = Math.min((totalPotential / GAP_TARGET) * 100, 100);
    document.getElementById("overall-value").innerHTML =
      `${formatRub(totalPotential)} <span>из ${formatRub(GAP_TARGET)}</span>`;
    document.getElementById("overall-bar").style.width = Math.max(overallPct, 0.5) + "%";
    document.getElementById("overall-pct-badge").textContent =
      overallPct.toFixed(1) + "% от цели";

    // Pie / breakdown
    const pieGrid = document.getElementById("pie-grid");
    pieGrid.innerHTML = "";

    // Card 1: Potential by team
    let potCard = `<div class="pie-card">
      <div class="pie-card-title">Потенциал по командам</div>`;
    sorted.forEach((r, i) => {
      const pct = totalPotential > 0 ? (r._potential / totalPotential * 100) : 0;
      potCard += `<div class="pie-bar-row">
        <div class="pie-bar-label" title="${r.team_name}">${r.team_name.replace("Группа ", "Гр.")}</div>
        <div class="pie-bar-track"><div class="pie-bar-fill" style="width:${pct.toFixed(1)}%;background:${BAR_COLORS[i]};"></div></div>
        <div class="pie-bar-val">${formatRub(r._potential)}</div>
      </div>`;
    });
    potCard += `</div>`;
    pieGrid.innerHTML += potCard;

    // Card 2: Methodology score
    let methCard = `<div class="pie-card">
      <div class="pie-card-title">Следование методологии DTBD</div>`;
    sorted.forEach((r, i) => {
      const score = parseFloat(r.methodology_score) || 0;
      methCard += `<div class="pie-bar-row">
        <div class="pie-bar-label" title="${r.team_name}">${r.team_name.replace("Группа ", "Гр.")}</div>
        <div class="pie-bar-track"><div class="pie-bar-fill" style="width:${score * 10}%;background:${getMethodColor(score)};"></div></div>
        <div class="pie-bar-val">${score}/10</div>
      </div>`;
    });
    methCard += `</div>`;
    pieGrid.innerHTML += methCard;

    // Card 3: Tasks completion
    let taskCard = `<div class="pie-card">
      <div class="pie-card-title">Выполнение задач спринта</div>`;
    sorted.forEach((r, i) => {
      const done = parseFloat(r.tasks_done) || 0;
      const total = parseFloat(r.tasks_total) || 1;
      const pct = (done / total) * 100;
      taskCard += `<div class="pie-bar-row">
        <div class="pie-bar-label" title="${r.team_name}">${r.team_name.replace("Группа ", "Гр.")}</div>
        <div class="pie-bar-track"><div class="pie-bar-fill" style="width:${pct.toFixed(1)}%;background:${BAR_COLORS[i]};"></div></div>
        <div class="pie-bar-val">${done}/${total}</div>
      </div>`;
    });
    taskCard += `</div>`;
    pieGrid.innerHTML += taskCard;

    // Team cards
    const teamsGrid = document.getElementById("teams-grid");
    teamsGrid.innerHTML = "";
    sorted.forEach((r, i) => {
      const rank = i + 1;
      const rankClass = `rank-${rank}`;
      const rankEmoji = ["🥇", "🥈", "🥉"][i] || "";
      const tasksDone = parseFloat(r.tasks_done) || 0;
      const tasksTotal = parseFloat(r.tasks_total) || 1;
      const methodScore = parseFloat(r.methodology_score) || 0;
      const taskPct = (tasksDone / tasksTotal) * 100;
      const hasInsight = r.super_insight_title && r.super_insight_title !== "—";

      // Build task checklist
      let taskListHtml = "";
      for (let t = 0; t < TASK_NAMES.length; t++) {
        const isDone = t < tasksDone;
        taskListHtml += `<div class="task-item">
          <div class="task-check ${isDone ? 'done' : 'pending'}">${isDone ? '✓' : ''}</div>
          <div class="task-text ${isDone ? 'done' : 'pending'}">${TASK_NAMES[t]}</div>
        </div>`;
      }

      // Insight block
      const insightHtml = hasInsight
        ? `<div class="insight-block">
            <div class="insight-label">⚡ Супер-инсайт найден</div>
            <div class="insight-title">${r.super_insight_title}</div>
            <div class="insight-core-job">${r.super_insight_core_job || ""}</div>
            <div class="insight-target">${r.super_insight_target || ""}</div>
          </div>`
        : `<div class="no-insight">Супер-инсайт ещё не найден</div>`;

      const avgCheck = parseFloat(r.avg_check) || 0;
      const margin = parseFloat(r.marginality) || 0;

      teamsGrid.innerHTML += `
        <div class="team-card ${rankClass}">
          <div class="team-card-header">
            <div class="team-rank">${rankEmoji}</div>
            <div class="team-name">${r.team_name}</div>
            <div class="team-sprint-badge">Спринт ${r.sprint}</div>
          </div>
          <div class="team-card-body">
            <div class="score-row">
              <div class="score-item">
                <div class="score-value" style="color:${getMethodColor(methodScore)}">${methodScore}/10</div>
                <div class="score-label">Методология</div>
              </div>
              <div class="score-item">
                <div class="score-value" style="color:${taskPct >= 80 ? '#22c55e' : taskPct >= 40 ? '#f5a623' : '#ef4444'}">${tasksDone}/${tasksTotal}</div>
                <div class="score-label">Задачи</div>
              </div>
              <div class="score-item">
                <div class="score-value" style="color:var(--beeline-yellow)">${r._score.toFixed(0)}</div>
                <div class="score-label">Балл</div>
              </div>
            </div>

            ${insightHtml}

            <div class="metric-row">
              <div class="metric-item">
                <div class="metric-header">
                  <div class="metric-label">Выполнение задач</div>
                  <div class="metric-value-sm">${taskPct.toFixed(0)}%</div>
                </div>
                <div class="mini-track">
                  <div class="mini-fill" style="width:${taskPct}%;background:${taskPct >= 80 ? '#22c55e' : taskPct >= 40 ? '#f5a623' : '#ef4444'};"></div>
                </div>
              </div>
              <div class="metric-item">
                <div class="metric-header">
                  <div class="metric-label">Следование DTBD</div>
                  <div class="metric-value-sm">${methodScore * 10}%</div>
                </div>
                <div class="mini-track">
                  <div class="mini-fill" style="width:${methodScore * 10}%;background:${getMethodColor(methodScore)};"></div>
                </div>
              </div>
              ${avgCheck > 0 ? `
              <div class="metric-item">
                <div class="metric-header">
                  <div class="metric-label">Средний чек</div>
                  <div class="metric-value-sm">${avgCheck.toLocaleString("ru")} ₽/мес · маржа ${margin}%</div>
                </div>
              </div>` : ""}
            </div>

            <div class="tasks-section">
              <div class="tasks-label">
                <span>Задачи недели</span>
                <span class="tasks-counter">${tasksDone} из ${tasksTotal}</span>
              </div>
              <div class="task-list">${taskListHtml}</div>
            </div>
          </div>
        </div>`;
    });

    // Main table
    const tbody = document.getElementById("main-table-body");
    tbody.innerHTML = "";
    sorted.forEach((r, i) => {
      const rank = i + 1;
      const tasksDone = parseFloat(r.tasks_done) || 0;
      const tasksTotal = parseFloat(r.tasks_total) || 1;
      const methodScore = parseFloat(r.methodology_score) || 0;
      const hasInsight = r.super_insight_title && r.super_insight_title !== "—";
      const avgCheck = parseFloat(r.avg_check) || 0;
      const margin = parseFloat(r.marginality) || 0;

      tbody.innerHTML += `<tr>
        <td><strong style="color:${TEAM_COLORS[i]}">${rank}</strong></td>
        <td class="td-team">${r.team_name}</td>
        <td class="td-insight">
          ${hasInsight
            ? `<div class="td-insight-title">${r.super_insight_title}</div>
               <div class="td-insight-sub">${r.super_insight_core_job || ""}</div>`
            : `<span style="color:var(--text-dim);font-size:12px;">Не найден</span>`}
        </td>
        <td class="td-segment">
          ${r.super_insight_target && r.super_insight_target !== "—"
            ? `<div class="td-segment-name">${r.super_insight_target}</div>
               ${avgCheck > 0 ? `<div class="td-segment-sub">Чек: ${avgCheck.toLocaleString("ru")} ₽/мес · Маржа: ${margin}%</div>` : ""}`
            : `<span style="color:var(--text-dim);font-size:12px;">—</span>`}
        </td>
        <td class="td-market">
          <div class="td-market-val">${formatRub(r._potential)}</div>
          <div class="td-market-sub">оценка потенциала</div>
        </td>
        <td class="td-tasks">${getTaskPill(tasksDone, tasksTotal)}</td>
        <td class="td-method">
          <div class="method-bar-wrap">
            <div class="method-score" style="color:${getMethodColor(methodScore)}">${methodScore}</div>
            <div class="method-track">
              <div class="method-fill" style="width:${methodScore * 10}%;background:${getMethodColor(methodScore)};"></div>
            </div>
          </div>
        </td>
      </tr>`;
    });
  }

  // Initial load
  loadData();
  // Auto-refresh every 5 minutes
  setInterval(loadData, 5 * 60 * 1000);
</script>

</body>
</html>
