---
import { getCollection } from 'astro:content';
import LandingLayout from '../layouts/LandingLayout.astro';

export async function getStaticPaths() {
  const landings = await getCollection('landings');
  return landings.map((landing) => ({
    params: { slug: landing.id },
    props: { landing },
  }));
}

const { landing } = Astro.props;
---

<LandingLayout {...landing.data} slug={landing.id}>
  {landing.body && (
    <section class="prose prose-lg mx-auto px-6 py-16">
      <Fragment set:html={landing.body} />
    </section>
  )}
</LandingLayout>
