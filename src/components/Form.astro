---
interface Props {
  formName: string;
  landingSlug: string;
}

const { formName = 'contact', landingSlug = '' } = Astro.props as Props;
---

<section id="contact" class="section section-muted">
  <div class="container form-card-wrap">
    <div class="section-heading center">
      <span class="eyebrow">Contact</span>
      <h2>Book a strategy call</h2>
      <p>Tell us about your product, timeline, and current constraints. We will come back with the most practical next step.</p>
    </div>

    <form
      name={formName}
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
      action="/thank-you"
      class="form-card"
    >
      <input type="hidden" name="form-name" value={formName} />
      <input type="hidden" name="landing_slug" value={landingSlug} />
      <input type="hidden" name="utm_source" value="" />
      <input type="hidden" name="utm_medium" value="" />
      <input type="hidden" name="utm_campaign" value="" />
      <input type="hidden" name="utm_content" value="" />
      <input type="hidden" name="utm_term" value="" />

      <p class="sr-only">
        <label>
          Don’t fill this out if you’re human:
          <input name="bot-field" />
        </label>
      </p>

      <div class="form-grid">
        <div>
          <label for="name" class="field-label">Name</label>
          <input type="text" id="name" name="name" required class="field-input" />
        </div>

        <div>
          <label for="email" class="field-label">Email</label>
          <input type="email" id="email" name="email" required class="field-input" />
        </div>

        <div>
          <label for="phone" class="field-label">Phone</label>
          <input type="tel" id="phone" name="phone" class="field-input" />
        </div>

        <div>
          <label for="company" class="field-label">Company</label>
          <input type="text" id="company" name="company" class="field-input" />
        </div>

        <div class="form-grid-full">
          <label for="message" class="field-label">Message</label>
          <textarea id="message" name="message" rows="5" class="field-input field-textarea"></textarea>
        </div>
      </div>

      <button type="submit" class="button button-primary button-block">
        Send request
      </button>
    </form>
  </div>
</section>

<script define:vars={{ landingSlug }}>
  import { populateUTMFields, trackFormSubmission } from '../utils/analytics.ts';

  const form = document.currentScript?.previousElementSibling?.querySelector('form');

  if (form instanceof HTMLFormElement) {
    populateUTMFields(form);
    form.addEventListener('submit', () => {
      populateUTMFields(form);
      trackFormSubmission(landingSlug);
    });
  }
</script>
