---
const { benefits = [] } = Astro.props;
---

<section class="solution py-20 bg-white">
  <div class="container mx-auto">
    <h2 class="text-4xl font-bold text-center mb-12">Our Solution</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {benefits.length > 0 ? (
        benefits.map((benefit) => (
          <div class="bg-blue-50 p-8 rounded-lg border-l-4 border-blue-600">
            <h3 class="text-xl font-semibold mb-4">{benefit.title}</h3>
            <p class="text-gray-700">{benefit.description}</p>
          </div>
        ))
      ) : (
        <div class="col-span-3 text-center text-gray-500">
          <p>No benefits defined yet.</p>
        </div>
      )}
    </div>
  </div>
</section>
